## Phase 1: Data Validation Layer (Foundation)

### 1.1 Create Validation Service

**File:** `src/services/validation.ts`

**Purpose:** Centralized validation for all data entering stores.

```typescript
// Validation schemas using Zod (already in package.json)
import { z } from 'zod';

// Calendar Event Schema
export const CalendarEventSchema = z.object({
  id: z.string().min(1),
  title: z.string().min(1),
  description: z.string().optional(),
  startTime: z.string().regex(/^\d{2}:\d{2}$/).optional(),
  endTime: z.string().regex(/^\d{2}:\d{2}$/).optional(),
  isAllDay: z.boolean().optional(),
  location: z.string().optional(),
  // ... rest of fields
});

// Note Schema
export const NoteSchema = z.object({
  id: z.string().min(1),
  title: z.string(),
  content: z.string(),
  folderId: z.string().nullable(),
  createdAt: z.union([z.date(), z.string()]),
  updatedAt: z.union([z.date(), z.string()]),
  // ... rest
});

// Task Schema
export const TaskSchema = z.object({
  id: z.string().min(1),
  title: z.string().min(1),
  status: z.enum(['backlog', 'todo', 'inprogress', 'review', 'done']),
  // ... rest
});

// DateKey Schema - CRITICAL
export const DateKeySchema = z.string().regex(
  /^\d{4}-(1[0-2]|[1-9])-([1-9]|[12]\d|3[01])$/,
  'Invalid date key format. Expected: YYYY-M-D'
);

// Brain Backup Schema
export const BrainBackupSchema = z.object({
  version: z.string(),
  appVersion: z.string(),
  exportDate: z.string().datetime(),
  data: z.object({
    notes: z.record(z.unknown()).optional(),
    'kanban-tasks': z.unknown().optional(),
    'calendar-events': z.unknown().optional(),
    folders: z.unknown().optional(),
  }),
});
```

**Benefits:**
- Single source of truth for data shapes
- Runtime validation before persistence
- Clear error messages for debugging
- Type inference for TypeScript

### 1.2 Add Validation to Import Functions

**File:** `src/services/brainBackup.ts`

```typescript
import { BrainBackupSchema, validateOrThrow } from './validation';

export async function importBrainFile(file: File): Promise<ImportResult> {
  try {
    const data = await readBrainFile(file);

    // Validate backup structure
    const validated = validateOrThrow(BrainBackupSchema, data, 'Brain backup');

    // Validate individual records
    const validationErrors: ValidationError[] = [];

    // Validate notes
    if (validated.data.notes) {
      for (const [id, note] of Object.entries(validated.data.notes)) {
        const result = NoteSchema.safeParse(note);
        if (!result.success) {
          validationErrors.push({ type: 'note', id, errors: result.error.issues });
        }
      }
    }

    // Return partial success if some records invalid
    if (validationErrors.length > 0) {
      return {
        success: 'partial',
        imported: { ... },
        errors: validationErrors,
      };
    }

    // Full success
    return { success: true, imported: { ... } };

  } catch (error) {
    return {
      success: false,
      error: error.message,
    };
  }
}
```

