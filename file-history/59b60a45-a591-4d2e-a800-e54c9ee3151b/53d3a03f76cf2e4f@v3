**Step 3.2: Preset Manager Component (2 hours)**

`src/components/PresetManager.tsx`:
```typescript
export const PresetManager: React.FC = () => {
  const [presets, setPresets] = useState<WidgetPreset[]>([]);
  const [showDialog, setShowDialog] = useState(false);
  const [presetName, setPresetName] = useState('');

  const savePreset = () => {
    const newPreset: WidgetPreset = {
      id: Date.now().toString(),
      name: presetName,
      widgets: useWidgetStore.getState().instances,
      createdAt: new Date().toISOString(),
    };

    const updated = [...presets, newPreset];
    setPresets(updated);
    localStorage.setItem('widget-presets', JSON.stringify(updated));
  };

  const loadPreset = (preset: WidgetPreset) => {
    useWidgetStore.getState().setInstances(preset.widgets);
  };

  return (
    <div className="preset-manager">
      <button onClick={() => setShowDialog(true)}>
        Save Layout
      </button>

      <div className="preset-list">
        {presets.map(preset => (
          <div key={preset.id} className="preset-item">
            <button onClick={() => loadPreset(preset)}>
              {preset.name}
            </button>
            <button onClick={() => deletePreset(preset.id)}>
              Delete
            </button>
          </div>
        ))}
      </div>
    </div>
  );
};
```

