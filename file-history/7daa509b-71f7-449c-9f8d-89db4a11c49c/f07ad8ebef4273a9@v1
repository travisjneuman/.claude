## Usage in Our Stack

### Archon — Agent Orchestration

LangGraph defines the workflow for Archon's agent-building process:

```python
# archon/graph.py
from langgraph.graph import StateGraph, END

class AgentBuilderState(TypedDict):
    requirements: str
    analysis: str
    tools: list[str]
    config: dict
    agent: Agent | None

def analyze_requirements(state: AgentBuilderState):
    """LLM analyzes user requirements."""
    response = llm.invoke(f"Analyze: {state['requirements']}")
    return {"analysis": response}

def select_tools(state: AgentBuilderState):
    """Select appropriate tools based on analysis."""
    tools = tool_selector.select(state["analysis"])
    return {"tools": tools}

def generate_config(state: AgentBuilderState):
    """Generate agent configuration."""
    config = config_generator.create(
        analysis=state["analysis"],
        tools=state["tools"]
    )
    return {"config": config}

# Build the graph
builder = StateGraph(AgentBuilderState)
builder.add_node("analyze", analyze_requirements)
builder.add_node("tools", select_tools)
builder.add_node("config", generate_config)

builder.add_edge("analyze", "tools")
builder.add_edge("tools", "config")
builder.add_edge("config", END)

builder.set_entry_point("analyze")
graph = builder.compile()
```

