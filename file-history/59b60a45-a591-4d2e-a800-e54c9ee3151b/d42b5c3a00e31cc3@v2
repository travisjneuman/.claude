#### 1.1 Create useEscapeKey Hook (NEW FILE)

**File:** `src/hooks/useEscapeKey.ts` (create new)

```typescript
import { useEffect } from 'react';

interface UseEscapeKeyOptions {
  enabled: boolean;        // Is ESC handling enabled?
  onEscape: () => void;    // Callback when ESC pressed
  priority?: number;       // z-index priority (higher = first)
}

/**
 * Centralized ESC key handler with priority system
 *
 * Usage:
 * useEscapeKey({
 *   enabled: isOpen,
 *   onEscape: () => setIsOpen(false),
 *   priority: 40 // z-index of component
 * });
 *
 * Components with higher priority (z-index) handle ESC first.
 * Event propagation stops after first handler.
 */
export function useEscapeKey({ enabled, onEscape, priority = 0 }: UseEscapeKeyOptions) {
  useEffect(() => {
    if (!enabled) return;

    const handleEscape = (e: KeyboardEvent) => {
      if (e.key === 'Escape') {
        // Store priority in event for coordination
        const currentPriority = (e as any)._escPriority || -1;

        if (priority > currentPriority) {
          (e as any)._escPriority = priority;
          e.stopPropagation();
          e.preventDefault();
          onEscape();
        }
      }
    };

    document.addEventListener('keydown', handleEscape, { capture: true });
    return () => document.removeEventListener('keydown', handleEscape, { capture: true });
  }, [enabled, onEscape, priority]);
}
```

