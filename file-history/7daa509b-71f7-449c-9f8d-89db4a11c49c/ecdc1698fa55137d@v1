## Advanced Patterns

### Slices Pattern

```typescript
// stores/slices/userSlice.ts
import { StateCreator } from "zustand";

export interface UserSlice {
  user: User | null;
  setUser: (user: User) => void;
  logout: () => void;
}

export const createUserSlice: StateCreator<
  UserSlice & OtherSlices,
  [],
  [],
  UserSlice
> = (set) => ({
  user: null,
  setUser: (user) => set({ user }),
  logout: () => set({ user: null }),
});
```

```typescript
// stores/slices/cartSlice.ts
import { StateCreator } from "zustand";

export interface CartSlice {
  items: CartItem[];
  addItem: (item: CartItem) => void;
  clearCart: () => void;
}

export const createCartSlice: StateCreator<
  UserSlice & CartSlice,
  [],
  [],
  CartSlice
> = (set) => ({
  items: [],
  addItem: (item) =>
    set((state) => ({ items: [...state.items, item] })),
  clearCart: () => set({ items: [] }),
});
```

```typescript
// stores/useStore.ts
import { create } from "zustand";
import { createUserSlice, UserSlice } from "./slices/userSlice";
import { createCartSlice, CartSlice } from "./slices/cartSlice";

type StoreState = UserSlice & CartSlice;

export const useStore = create<StoreState>()((...args) => ({
  ...createUserSlice(...args),
  ...createCartSlice(...args),
}));
```

### Computed Values (Selectors)

```typescript
// stores/useCartStore.ts
import { create } from "zustand";

interface CartState {
  items: { id: string; price: number; quantity: number }[];
  addItem: (item: CartState["items"][0]) => void;
}

export const useCartStore = create<CartState>()((set) => ({
  items: [],
  addItem: (item) =>
    set((state) => ({ items: [...state.items, item] })),
}));

// Derived selectors (outside store)
export const selectTotalItems = (state: CartState) =>
  state.items.reduce((sum, item) => sum + item.quantity, 0);

export const selectTotalPrice = (state: CartState) =>
  state.items.reduce((sum, item) => sum + item.price * item.quantity, 0);

// Usage
function CartSummary() {
  const totalItems = useCartStore(selectTotalItems);
  const totalPrice = useCartStore(selectTotalPrice);

  return (
    <div>
      <p>Items: {totalItems}</p>
      <p>Total: ${totalPrice}</p>
    </div>
  );
}
```

### Subscribe to Changes

```typescript
// Subscribe outside React
const unsubscribe = useStore.subscribe(
  (state) => state.user,
  (user, prevUser) => {
    console.log("User changed:", prevUser, "->", user);
  }
);

// Cleanup
unsubscribe();
```

### Access State Outside React

```typescript
// Get current state
const currentUser = useUserStore.getState().user;

// Update state
useUserStore.setState({ user: newUser });

// Useful for API interceptors, utilities, etc.
api.interceptors.request.use((config) => {
  const token = useAuthStore.getState().token;
  if (token) {
    config.headers.Authorization = `Bearer ${token}`;
  }
  return config;
});
