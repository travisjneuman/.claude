{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "permissions": {
    "allow": [
      "Skill(run-prompt *)",
      "Skill(taches-cc-resources:*)",
      "Skill(gsd:*)",
      "Skill(commit-commands:*)",
      "Skill(feature-dev:*)",
      "Skill(pr-review-toolkit:*)",
      "Bash(git *)",
      "Bash(test *)",
      "Bash(npm *)",
      "Bash(npx *)",
      "Bash(pnpm *)",
      "Bash(yarn *)",
      "Bash(node *)",
      "Bash(python *)",
      "Bash(python3 *)",
      "Bash(pip *)",
      "Bash(uv *)",
      "Bash(ruff *)",
      "Bash(mypy *)",
      "Bash(pytest *)",
      "Bash(docker *)",
      "Bash(docker-compose *)",
      "Bash(gh *)",
      "Bash(curl *)",
      "Bash(wget *)",
      "Bash(cat *)",
      "Bash(ls *)",
      "Bash(dir *)",
      "Bash(find *)",
      "Bash(findstr *)",
      "Bash(tree *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(wc *)",
      "Bash(mkdir *)",
      "Bash(cp *)",
      "Bash(mv *)",
      "Bash(powershell -Command *)",
      "Bash(Get-ChildItem *)",
      "Bash(Get-NetTCPConnection *)",
      "Bash(Select-Object *)",
      "Bash(ForEach-Object *)",
      "Bash(Format-Table *)",
      "Skill(tech-debt-analyzer)",
      "Skill(debug-like-expert)",
      "Skill(generic-code-reviewer)",
      "Skill(generic-feature-developer)",
      "Skill(test-specialist)",
      "Skill(codebase-documenter)",
      "WebSearch",
      "WebFetch(domain:docs.anthropic.com)",
      "WebFetch(domain:awesomeclaude.ai)",
      "WebFetch(domain:docs.claude.com)",
      "WebFetch(domain:claudemarketplaces.com)",
      "WebFetch(domain:code.claude.com)",
      "WebFetch(domain:registry.modelcontextprotocol.io)",
      "WebFetch(domain:mcpservers.org)",
      "WebFetch(domain:mcpcat.io)",
      "WebFetch(domain:modelcontextprotocol.io)",
      "WebFetch(domain:react.dev)",
      "WebFetch(domain:nextjs.org)",
      "WebFetch(domain:typescriptlang.org)",
      "WebFetch(domain:nodejs.org)",
      "WebFetch(domain:developer.mozilla.org)",
      "WebFetch(domain:github.com)",
      "mcp__memory__*",
      "mcp__filesystem__read_file",
      "mcp__filesystem__list_directory",
      "mcp__sqlite__read_query",
      "mcp__sequential-thinking__*"
    ],
    "deny": [
      "mcp__filesystem__write_file",
      "mcp__filesystem__delete_file"
    ],
    "ask": [],
    "defaultMode": "bypassPermissions"
  },
  "enableAllProjectMcpServers": false,
  "disabledMcpjsonServers": [
    "sequential-thinking",
    "playwright",
    "memory",
    "filesystem",
    "sqlite",
    "context7",
    "chrome-devtools",
    "puppeteer",
    "browserbase",
    "github",
    "postgres",
    "git"
  ],
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node -e \"process.env.HOOK_NAME='session-start-pull.sh';require(require('path').join(require('os').homedir(),'.claude','hooks','run-hook'))\"",
            "statusMessage": "Pulling repos in background",
            "once": true,
            "async": true
          },
          {
            "type": "command",
            "command": "node -e \"process.env.HOOK_NAME='session-start-context.sh';require(require('path').join(require('os').homedir(),'.claude','hooks','run-hook'))\"",
            "statusMessage": "Loading previous session context",
            "once": true
          },
          {
            "type": "command",
            "command": "node -e \"process.env.HOOK_NAME='session-start-repo-health.sh';require(require('path').join(require('os').homedir(),'.claude','hooks','run-hook'))\"",
            "statusMessage": "Checking repo health",
            "once": true
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"C:/Users/tjn/.claude/hooks/gsd-check-update.js\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node -e \"process.env.HOOK_NAME='session-stop-summary.sh';require(require('path').join(require('os').homedir(),'.claude','hooks','run-hook'))\"",
            "statusMessage": "Saving session summary"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node -e \"process.env.HOOK_NAME='prompt-context.sh';require(require('path').join(require('os').homedir(),'.claude','hooks','run-hook'))\"",
            "statusMessage": "Injecting git context"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node -e \"process.env.HOOK_NAME='pre-bash-check.sh';require(require('path').join(require('os').homedir(),'.claude','hooks','run-hook'))\"",
            "statusMessage": "Checking command"
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node -e \"process.env.HOOK_NAME='pre-write-validate.sh';require(require('path').join(require('os').homedir(),'.claude','hooks','run-hook'))\"",
            "statusMessage": "Validating file path"
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node \"C:/Users/tjn/.claude/hooks/gsd-prompt-guard.js\"",
            "timeout": 5
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node -e \"process.env.HOOK_NAME='session-stop-summary.sh';require(require('path').join(require('os').homedir(),'.claude','hooks','run-hook'))\"",
            "statusMessage": "Saving session context before compaction"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node -e \"process.env.HOOK_NAME='secret-scan.sh';require(require('path').join(require('os').homedir(),'.claude','hooks','run-hook'))\"",
            "statusMessage": "Scanning for secrets"
          }
        ]
      },
      {
        "matcher": "Bash|Edit|Write|MultiEdit|Agent|Task",
        "hooks": [
          {
            "type": "command",
            "command": "node \"C:/Users/tjn/.claude/hooks/gsd-context-monitor.js\"",
            "timeout": 10
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node -e \"process.env.HOOK_NAME='session-stop-summary.sh';require(require('path').join(require('os').homedir(),'.claude','hooks','run-hook'))\"",
            "statusMessage": "Saving session summary on exit"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "node -e \"process.env.HOOK_NAME='statusline.sh';require(require('path').join(require('os').homedir(),'.claude','hooks','run-hook'))\""
  },
  "enabledPlugins": {
    "agent-sdk-dev@claude-code-plugins": true,
    "pr-review-toolkit@claude-code-plugins": true,
    "commit-commands@claude-code-plugins": true,
    "feature-dev@claude-code-plugins": true,
    "security-guidance@claude-code-plugins": false,
    "code-review@claude-code-plugins": true,
    "explanatory-output-style@claude-code-plugins": false,
    "learning-output-style@claude-code-plugins": false,
    "frontend-design@claude-code-plugins": true,
    "document-skills@anthropic-agent-skills": true,
    "example-skills@anthropic-agent-skills": false,
    "taches-cc-resources@taches-cc-resources": true,
    "claude-opus-4-5-migration@claude-code-plugins": false,
    "hookify@claude-code-plugins": false,
    "plugin-dev@claude-code-plugins": true,
    "ralph-wiggum@claude-code-plugins": false
  },
  "outputStyle": "default",
  "spinnerTipsEnabled": false,
  "effortLevel": "xhigh",
  "autoUpdatesChannel": "latest",
  "skipDangerousModePermissionPrompt": true,
  "verbose": true,
  "fileCheckpointingEnabled": false,
  "teammateMode": "auto",
  "remoteControlAtStartup": true,
  "skipAutoPermissionPrompt": true
}
