## Data Handling & State Management

### Local State (useState)

Use for widget-specific UI state:

```typescript
const [selectedTab, setSelectedTab] = useState<'overview' | 'details'>('overview');
const [isExpanded, setIsExpanded] = useState(false);
const [inputValue, setInputValue] = useState('');
```

### Global State (Zustand Stores)

Use for app-wide data shared across widgets:

```typescript
import { useNotesStore } from '../../stores/useNotesStore';
import { useKanbanStore } from '../../stores/useKanbanStore';
import { useCalendarStore } from '../../stores/useCalendarStore';

export const TaskSummaryWidget: React.FC = () => {
  // Access global Kanban state
  const tasks = useKanbanStore((state) => state.tasks);
  const todoCount = tasks.filter(t => t.status === 'todo').length;

  return (
    <BaseWidget title="Task Summary" icon="✅">
      <p>{todoCount} tasks remaining</p>
    </BaseWidget>
  );
};
```

### Widget Settings (useWidgetStore)

For widget-specific configuration (saved to IndexedDB):

```typescript
import { useWidgetStore } from '../../stores/useWidgetStore';

export const WeatherWidget: React.FC = () => {
  const widgetSettings = useWidgetStore((state) => state.widgetSettings);
  const updateWidgetSettings = useWidgetStore((state) => state.updateWidgetSettings);

  // Get widget-specific settings
  const city = widgetSettings.weather?.city || 'New York';
  const unit = widgetSettings.weather?.unit || 'fahrenheit';

  // Update settings
  const handleCityChange = (newCity: string) => {
    updateWidgetSettings('weather', { city: newCity, unit });
  };

  // Use settings in API call
  const fetchWeather = async () => {
    const response = await fetch(`https://api.example.com/weather?city=${city}&unit=${unit}`);
    // ...
  };
};
```

