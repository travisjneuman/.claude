#!/usr/bin/env python3
"""
Generate HTML Review Report
Creates an interactive HTML report for reviewing duplicate groups
with thumbnails and version comparisons.
"""

import json
import base64
import zipfile
from pathlib import Path
from datetime import datetime

# Configuration
BASE_PATH = Path(r"D:\Proton Drive\My files\Documents\Personal\Notebooks")
OUTPUT_DIR = BASE_PATH / "_scripts" / "output"
DUPLICATES_JSON = OUTPUT_DIR / "duplicates.json"
OUTPUT_HTML = OUTPUT_DIR / "duplicate_review.html"

def get_thumbnail_base64(note_path: Path) -> str:
    """Extract thumbnail from .note file and return as base64."""
    try:
        with zipfile.ZipFile(note_path, 'r') as z:
            # Try to find best thumbnail
            for thumb_name in ['thumb6x.png', 'thumb3x.png', 'thumb2x.png', 'thumb.png']:
                for name in z.namelist():
                    if name.endswith(thumb_name):
                        data = z.read(name)
                        return base64.b64encode(data).decode('utf-8')
    except:
        pass
    return ""

def generate_html(duplicates: dict) -> str:
    """Generate HTML report content."""

    html = '''<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Duplicate Review Report</title>
    <style>
        * { box-sizing: border-box; }
        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, sans-serif;
            margin: 0;
            padding: 20px;
            background: #1a1a2e;
            color: #eee;
        }
        h1 { color: #00d4ff; text-align: center; }
        h2 { color: #ff6b6b; margin-top: 40px; }
        h3 { color: #4ecdc4; }

        .stats {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 20px;
            margin: 20px 0;
        }
        .stat-card {
            background: #16213e;
            padding: 20px;
            border-radius: 10px;
            text-align: center;
        }
        .stat-value { font-size: 2em; color: #00d4ff; }
        .stat-label { color: #888; }

        .group {
            background: #16213e;
            padding: 20px;
            border-radius: 10px;
            margin: 20px 0;
        }
        .group-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 15px;
        }
        .group-title {
            font-size: 1.2em;
            color: #4ecdc4;
        }
        .group-count {
            background: #ff6b6b;
            padding: 5px 15px;
            border-radius: 20px;
            font-size: 0.9em;
        }

        .versions {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
            gap: 15px;
        }
        .version {
            background: #1a1a2e;
            padding: 15px;
            border-radius: 8px;
            border: 2px solid #333;
        }
        .version.recommended {
            border-color: #4ecdc4;
        }
        .version-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 10px;
        }
        .version-name {
            font-weight: bold;
            word-break: break-all;
        }
        .recommended-badge {
            background: #4ecdc4;
            color: #000;
            padding: 3px 10px;
            border-radius: 15px;
            font-size: 0.8em;
        }
        .thumbnail {
            width: 100%;
            max-height: 200px;
            object-fit: contain;
            background: #0a0a14;
            border-radius: 5px;
            margin: 10px 0;
        }
        .no-thumbnail {
            width: 100%;
            height: 100px;
            background: #0a0a14;
            border-radius: 5px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #666;
        }
        .version-stats {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 5px;
            font-size: 0.85em;
            color: #888;
        }
        .version-stat {
            background: #0a0a14;
            padding: 5px 10px;
            border-radius: 3px;
        }

        .section { margin-top: 40px; }

        .filter-bar {
            position: sticky;
            top: 0;
            background: #1a1a2e;
            padding: 15px 0;
            z-index: 100;
            border-bottom: 1px solid #333;
            margin-bottom: 20px;
        }
        .filter-input {
            width: 100%;
            max-width: 400px;
            padding: 10px 15px;
            border: 1px solid #333;
            border-radius: 5px;
            background: #16213e;
            color: #eee;
            font-size: 1em;
        }

        .action-buttons {
            margin-top: 15px;
            display: flex;
            gap: 10px;
        }
        .btn {
            padding: 8px 15px;
            border: none;
            border-radius: 5px;
            cursor: pointer;
            font-size: 0.9em;
        }
        .btn-keep { background: #4ecdc4; color: #000; }
        .btn-remove { background: #ff6b6b; color: #fff; }
    </style>
</head>
<body>
    <h1>Duplicate Review Report</h1>
    <p style="text-align: center; color: #888;">Generated: ''' + datetime.now().strftime("%Y-%m-%d %H:%M:%S") + '''</p>

    <div class="stats">
        <div class="stat-card">
            <div class="stat-value">''' + str(duplicates['stats']['total_files']) + '''</div>
            <div class="stat-label">Total Files</div>
        </div>
        <div class="stat-card">
            <div class="stat-value">''' + str(duplicates['stats']['groups_with_duplicates']) + '''</div>
            <div class="stat-label">Duplicate Groups</div>
        </div>
        <div class="stat-card">
            <div class="stat-value">''' + str(duplicates['stats']['byte_identical_groups']) + '''</div>
            <div class="stat-label">Byte-Identical</div>
        </div>
        <div class="stat-card">
            <div class="stat-value">''' + str(duplicates['stats']['version_variant_groups']) + '''</div>
            <div class="stat-label">Version Variants</div>
        </div>
    </div>

    <div class="filter-bar">
        <input type="text" class="filter-input" placeholder="Filter by name..." oninput="filterGroups(this.value)">
    </div>
'''

    # Byte-identical duplicates section
    html += '''
    <div class="section">
        <h2>Byte-Identical Duplicates (''' + str(len(duplicates['byte_identical'])) + ''' groups)</h2>
        <p style="color: #888;">These files are exact copies. Safe to keep only the recommended version.</p>
'''

    for group in duplicates['byte_identical'][:30]:  # Limit to first 30
        html += f'''
        <div class="group" data-name="{group['base_name'].lower()}">
            <div class="group-header">
                <span class="group-title">{group['base_name']}</span>
                <span class="group-count">{group['count']} copies</span>
            </div>
            <div class="versions">
                <div class="version recommended">
                    <div class="version-header">
                        <span class="version-name">{group['keep']['filename']}</span>
                        <span class="recommended-badge">KEEP</span>
                    </div>
                    <div class="version-stats">
                        <div class="version-stat">Size: {group['keep']['size'] // 1024} KB</div>
                    </div>
                </div>
'''
        for rem in group['remove'][:3]:  # Show first 3 to remove
            html += f'''
                <div class="version">
                    <div class="version-header">
                        <span class="version-name">{rem['filename']}</span>
                    </div>
                    <div class="version-stats">
                        <div class="version-stat">Size: {rem['size'] // 1024} KB</div>
                    </div>
                </div>
'''
        if len(group['remove']) > 3:
            html += f'''
                <div class="version" style="background: #0a0a14;">
                    <div style="text-align: center; color: #666; padding: 20px;">
                        +{len(group['remove']) - 3} more duplicates
                    </div>
                </div>
'''
        html += '''
            </div>
        </div>
'''

    html += '</div>'

    # Version variants section
    html += '''
    <div class="section">
        <h2>Version Variants (''' + str(len(duplicates['version_variants'])) + ''' groups)</h2>
        <p style="color: #888;">These files have different content. Review carefully before deciding which to keep.</p>
'''

    for group in duplicates['version_variants'][:20]:  # Limit to first 20
        html += f'''
        <div class="group" data-name="{group['base_name'].lower()}">
            <div class="group-header">
                <span class="group-title">{group['base_name']}</span>
                <span class="group-count">{group['count']} versions ({group['unique_hashes']} unique)</span>
            </div>
            <div class="versions">
'''
        for v in group['versions'][:6]:  # Show first 6 versions
            rec_class = 'recommended' if v['is_recommended'] else ''
            rec_badge = '<span class="recommended-badge">RECOMMENDED</span>' if v['is_recommended'] else ''

            # Try to get thumbnail
            thumb_b64 = ""
            try:
                thumb_b64 = get_thumbnail_base64(Path(v['path']))
            except:
                pass

            thumb_html = f'<img class="thumbnail" src="data:image/png;base64,{thumb_b64}" alt="Thumbnail">' if thumb_b64 else '<div class="no-thumbnail">No thumbnail</div>'

            html += f'''
                <div class="version {rec_class}">
                    <div class="version-header">
                        <span class="version-name">{v['filename']}</span>
                        {rec_badge}
                    </div>
                    {thumb_html}
                    <div class="version-stats">
                        <div class="version-stat">Size: {v['size'] // 1024} KB</div>
                        <div class="version-stat">Files: {v['internal_files']}</div>
                        <div class="version-stat">Images: {v['image_count']}</div>
                        <div class="version-stat">PDFs: {v['pdf_count']}</div>
                    </div>
                </div>
'''

        if len(group['versions']) > 6:
            html += f'''
                <div class="version" style="background: #0a0a14;">
                    <div style="text-align: center; color: #666; padding: 20px;">
                        +{len(group['versions']) - 6} more versions
                    </div>
                </div>
'''

        html += '''
            </div>
        </div>
'''

    html += '''
    </div>

    <script>
        function filterGroups(query) {
            const groups = document.querySelectorAll('.group');
            query = query.toLowerCase();
            groups.forEach(group => {
                const name = group.dataset.name;
                group.style.display = name.includes(query) ? 'block' : 'none';
            });
        }
    </script>
</body>
</html>'''

    return html

def main():
    print("=" * 60)
    print("Generate HTML Review Report")
    print("=" * 60)

    # Load duplicates data
    if not DUPLICATES_JSON.exists():
        print(f"ERROR: {DUPLICATES_JSON} not found. Run 03_analyze_duplicates.py first.")
        return

    print(f"\nLoading: {DUPLICATES_JSON}")
    with open(DUPLICATES_JSON, 'r', encoding='utf-8') as f:
        duplicates = json.load(f)

    print(f"Generating HTML report...")
    html = generate_html(duplicates)

    print(f"Writing: {OUTPUT_HTML}")
    with open(OUTPUT_HTML, 'w', encoding='utf-8') as f:
        f.write(html)

    print("\n" + "=" * 60)
    print("REPORT GENERATED")
    print("=" * 60)
    print(f"Open in browser: {OUTPUT_HTML}")
    print("=" * 60)

if __name__ == '__main__':
    main()
