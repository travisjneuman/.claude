### Part 6: Dependency Validation (2-3 hours)

**Goal:** Prevent invalid dependencies and moving blocked tasks

**Files to Modify:**
1. `src/stores/useKanbanStore.ts` - Add validation in moveTask
2. `src/widgets/Kanban/KanbanCard.tsx` - Add visual indicators

**Features:**
- Prevent circular dependencies (A blocks B, B blocks A)
- Show warning when trying to complete blocked task
- Prevent dragging blocked task to "Done" column
- Show 🔒 icon on blocked cards
- Show ⚠️ icon on blocker cards

**Implementation:**
```typescript
// Validation in addDependency
addDependency: (sourceTaskId: string, targetTaskId: string) => {
  // Prevent self-dependency
  if (sourceTaskId === targetTaskId) {
    throw new Error('Task cannot depend on itself');
  }

  // Prevent circular dependency
  const existingDependencies = get().dependencies;
  const wouldCreateCycle = checkForCycle(existingDependencies, sourceTaskId, targetTaskId);
  if (wouldCreateCycle) {
    throw new Error('This would create a circular dependency');
  }

  // Add dependency
  // ...
},

// Validation in moveTask
moveTask: (taskId: string, newStatus: TaskStatus) => {
  const task = get().tasks.find(t => t.id === taskId);
  if (!task) return;

  // Check if moving to done but has blockers
  if (newStatus === 'done') {
    const blockers = get().getBlockers(taskId);
    const incompleteBlockers = blockers.filter(b => b.status !== 'done');

    if (incompleteBlockers.length > 0) {
      // Show toast notification
      console.warn(`Cannot complete: Blocked by ${incompleteBlockers.length} task(s)`);
      return; // Prevent move
    }
  }

  // Move task
  // ...
},
```

