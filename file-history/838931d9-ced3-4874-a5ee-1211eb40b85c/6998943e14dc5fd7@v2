### 7. Auto-Generate Activity Log Entries

**File:** `src/stores/useKanbanStore.ts`

Update `updateTask` action to auto-log changes:
```typescript
updateTask: (id, updates) => {
  const task = get().tasks.find(t => t.id === id);
  if (!task) return;

  const activityLog = task.activityLog || [];

  // Generate activity entries for changes
  Object.keys(updates).forEach(field => {
    if (updates[field] !== task[field]) {
      activityLog.push({
        id: `activity-${Date.now()}-${Math.random()}`,
        timestamp: new Date().toISOString(),
        action: `Changed ${field} from "${task[field]}" to "${updates[field]}"`,
        field,
        oldValue: String(task[field]),
        newValue: String(updates[field]),
      });
    }
  });

  set(state => ({
    tasks: state.tasks.map(t =>
      t.id === id ? { ...t, ...updates, activityLog } : t
    ),
  }));
},
```

