---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';

export async function getStaticPaths() {
  const properties = await getCollection('properties');
  return properties.map((property) => ({
    params: { slug: property.slug },
    props: { property },
  }));
}

interface Props {
  property: CollectionEntry<'properties'>;
}

const { property } = Astro.props;
const { data, slug } = property;
const { Content } = await property.render();

// Status styles
const statusStyles = {
  available: 'badge-available',
  pending: 'badge-pending',
  rented: 'badge-rented',
} as const;

const statusLabels = {
  available: 'Available Now',
  pending: 'Application Pending',
  rented: 'Currently Rented',
} as const;

// Pet policy labels
const petLabels = {
  'no-pets': 'No Pets Allowed',
  'cats-only': 'Cats Allowed',
  'dogs-only': 'Dogs Allowed',
  'cats-dogs': 'Cats & Dogs Allowed',
  'negotiable': 'Pets Negotiable',
} as const;

// Parking labels
const parkingLabels = {
  'none': 'Street Parking',
  'street': 'Street Parking',
  'lot': 'Parking Lot',
  'garage': 'Garage Parking',
  'covered': 'Covered Parking',
} as const;

// Laundry labels
const laundryLabels = {
  'none': 'No Laundry',
  'shared': 'Shared Laundry',
  'in-unit': 'In-Unit Laundry',
  'hookups': 'Washer/Dryer Hookups',
} as const;

// Format available date
const formatDate = (date: Date | undefined) => {
  if (!date) return 'Flexible';
  return date.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' });
};
---

<BaseLayout
  title={data.title}
  description={`${data.beds} bed, ${data.baths} bath ${data.propertyType} for rent in ${data.neighborhood}, ${data.city}. $${data.rent.toLocaleString()}/month.`}
>
  <!-- Breadcrumb -->
  <nav class="bg-theme-tertiary border-b border-theme-primary" aria-label="Breadcrumb">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-3">
      <ol class="flex items-center gap-2 text-sm">
        <li>
          <a href="/" class="text-theme-tertiary hover:text-theme-primary">Home</a>
        </li>
        <li class="text-theme-tertiary">/</li>
        <li>
          <a href="/properties" class="text-theme-tertiary hover:text-theme-primary">Properties</a>
        </li>
        <li class="text-theme-tertiary">/</li>
        <li class="text-theme-primary font-medium truncate max-w-[200px]" aria-current="page">
          {data.title}
        </li>
      </ol>
    </div>
  </nav>

  <article class="py-8 md:py-12">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

      <!-- Header Section -->
      <header class="mb-8">
        <div class="flex flex-wrap items-start justify-between gap-4 mb-4">
          <div>
            <span class={`inline-block px-3 py-1 rounded-full text-sm font-medium mb-3 ${statusStyles[data.status]}`}>
              {statusLabels[data.status]}
            </span>
            <h1 class="text-3xl md:text-4xl font-bold text-theme-primary">{data.title}</h1>
            <p class="text-lg text-theme-secondary mt-2">
              {data.neighborhood}, {data.city}, {data.state}
            </p>
          </div>
          <div class="text-right">
            <p class="text-3xl md:text-4xl font-bold text-primary-500">
              ${data.rent.toLocaleString()}<span class="text-lg font-normal text-theme-tertiary">/mo</span>
            </p>
            <p class="text-sm text-theme-tertiary mt-1">
              ${data.deposit.toLocaleString()} deposit
            </p>
          </div>
        </div>
      </header>

      <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">

        <!-- Main Content -->
        <div class="lg:col-span-2">

          <!-- Photo Gallery -->
          <div class="mb-8">
            {data.photos.length === 1 ? (
              <div class="aspect-video rounded-xl overflow-hidden bg-theme-tertiary">
                <img
                  src={data.photos[0]}
                  alt={`Photo of ${data.title}`}
                  class="w-full h-full object-cover"
                />
              </div>
            ) : (
              <div class="grid grid-cols-2 gap-4">
                {data.photos.slice(0, 4).map((photo, index) => (
                  <div class={`${index === 0 ? 'col-span-2 aspect-video' : 'aspect-square'} rounded-xl overflow-hidden bg-theme-tertiary`}>
                    <img
                      src={photo}
                      alt={`Photo ${index + 1} of ${data.title}`}
                      class="w-full h-full object-cover hover:scale-105 transition-transform cursor-pointer"
                      loading={index === 0 ? 'eager' : 'lazy'}
                    />
                  </div>
                ))}
              </div>
            )}
          </div>

          <!-- Property Stats -->
          <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 mb-8">
            <div class="bg-theme-tertiary rounded-lg p-4 text-center">
              <p class="text-2xl font-bold text-theme-primary">{data.beds}</p>
              <p class="text-sm text-theme-secondary">Bedrooms</p>
            </div>
            <div class="bg-theme-tertiary rounded-lg p-4 text-center">
              <p class="text-2xl font-bold text-theme-primary">{data.baths}</p>
              <p class="text-sm text-theme-secondary">Bathrooms</p>
            </div>
            {data.sqft && (
              <div class="bg-theme-tertiary rounded-lg p-4 text-center">
                <p class="text-2xl font-bold text-theme-primary">{data.sqft.toLocaleString()}</p>
                <p class="text-sm text-theme-secondary">Sq Ft</p>
              </div>
            )}
            <div class="bg-theme-tertiary rounded-lg p-4 text-center">
              <p class="text-2xl font-bold text-theme-primary capitalize">{data.propertyType}</p>
              <p class="text-sm text-theme-secondary">Type</p>
            </div>
          </div>

          <!-- Description -->
          <div class="prose prose-gray max-w-none mb-8">
            <Content />
          </div>

          <!-- Features -->
          {data.features && data.features.length > 0 && (
            <div class="mb-8">
              <h2 class="text-xl font-semibold text-theme-primary mb-4">Features & Amenities</h2>
              <ul class="grid grid-cols-1 sm:grid-cols-2 gap-3">
                {data.features.map((feature) => (
                  <li class="flex items-center gap-2 text-theme-secondary">
                    <svg class="w-5 h-5 text-accent-500 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                      <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                    </svg>
                    {feature}
                  </li>
                ))}
              </ul>
            </div>
          )}
        </div>

        <!-- Sidebar -->
        <aside class="lg:col-span-1">
          <div class="sticky top-24 space-y-6">

            <!-- Quick Facts Card -->
            <div class="bg-theme-primary rounded-xl shadow-md border border-theme-primary p-6">
              <h2 class="text-lg font-semibold text-theme-primary mb-4">Property Details</h2>

              <dl class="space-y-4">
                <div class="flex justify-between">
                  <dt class="text-theme-secondary">Available</dt>
                  <dd class="font-medium text-theme-primary">{formatDate(data.availableDate)}</dd>
                </div>
                <div class="flex justify-between">
                  <dt class="text-theme-secondary">Pet Policy</dt>
                  <dd class="font-medium text-theme-primary">{petLabels[data.petPolicy]}</dd>
                </div>
                <div class="flex justify-between">
                  <dt class="text-theme-secondary">Parking</dt>
                  <dd class="font-medium text-theme-primary">{parkingLabels[data.parking]}</dd>
                </div>
                <div class="flex justify-between">
                  <dt class="text-theme-secondary">Laundry</dt>
                  <dd class="font-medium text-theme-primary">{laundryLabels[data.laundry]}</dd>
                </div>
                {data.applicationFee && (
                  <div class="flex justify-between">
                    <dt class="text-theme-secondary">Application Fee</dt>
                    <dd class="font-medium text-theme-primary">${data.applicationFee}</dd>
                  </div>
                )}
              </dl>
            </div>

            <!-- CTA Card -->
            {data.status === 'available' && (
              <div class="bg-primary-50 rounded-xl border border-primary-200 p-6">
                <h2 class="text-lg font-semibold text-theme-primary mb-2">Interested in this property?</h2>
                <p class="text-sm text-theme-secondary mb-4">
                  Schedule a viewing or submit an application today.
                </p>

                <div class="space-y-3">
                  <a
                    href={data.applyUrl}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="block w-full text-center px-4 py-3 bg-primary-600 text-white font-semibold rounded-lg hover:bg-primary-700 transition-colors touch-target"
                  >
                    Apply Now
                  </a>
                  <a
                    href="/contact"
                    class="block w-full text-center px-4 py-3 bg-theme-primary text-primary-600 font-semibold rounded-lg border border-primary-300 hover:bg-primary-50 transition-colors touch-target"
                  >
                    Schedule Viewing
                  </a>
                </div>
              </div>
            )}

            {data.status === 'pending' && (
              <div class="bg-yellow-50 rounded-xl border border-yellow-200 p-6">
                <h2 class="text-lg font-semibold text-gray-900 mb-2">Application Pending</h2>
                <p class="text-sm text-gray-600 mb-4">
                  This property has an application pending. Contact us to be added to the waitlist.
                </p>
                <a
                  href="/contact"
                  class="block w-full text-center px-4 py-3 bg-yellow-600 text-white font-semibold rounded-lg hover:bg-yellow-700 transition-colors touch-target"
                >
                  Join Waitlist
                </a>
              </div>
            )}

            {data.status === 'rented' && (
              <div class="bg-theme-tertiary rounded-xl border border-theme-primary p-6">
                <h2 class="text-lg font-semibold text-theme-primary mb-2">Currently Rented</h2>
                <p class="text-sm text-theme-secondary mb-4">
                  This property is currently occupied. Contact us to be notified when it becomes available.
                </p>
                <a
                  href="/contact"
                  class="block w-full text-center px-4 py-3 bg-gray-600 text-white font-semibold rounded-lg hover:bg-gray-700 transition-colors touch-target"
                >
                  Get Notified
                </a>
              </div>
            )}

            <!-- Contact Card -->
            <div class="bg-theme-primary rounded-xl shadow-md border border-theme-primary p-6">
              <h2 class="text-lg font-semibold text-theme-primary mb-4">Questions?</h2>
              <p class="text-sm text-theme-secondary mb-4">
                Have questions about this property? We're here to help.
              </p>
              <a
                href="/contact"
                class="flex items-center justify-center gap-2 w-full px-4 py-3 text-primary-600 font-medium rounded-lg border border-primary-300 hover:bg-primary-50 transition-colors touch-target"
              >
                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                </svg>
                Contact Us
              </a>
            </div>
          </div>
        </aside>
      </div>

      <!-- Back Link -->
      <div class="mt-12 pt-8 border-t border-theme-primary">
        <a
          href="/properties"
          class="inline-flex items-center gap-2 text-primary-500 hover:text-primary-600 font-medium transition-colors"
        >
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
          </svg>
          Back to All Properties
        </a>
      </div>
    </div>
  </article>
</BaseLayout>
