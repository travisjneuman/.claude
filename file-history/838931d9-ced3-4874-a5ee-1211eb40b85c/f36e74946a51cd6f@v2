import React, { useMemo } from 'react';
import { useNavigate } from 'react-router-dom';
import { Widget } from '../../components/Widget';
import { useCalendarStore } from '../../stores/useCalendarStore';
import {
  getLegacyDateKey,
  getFirstDayOfMonth,
  getDaysInMonth,
  getDaysInPrevMonth,
  isToday,
} from '../../utils/dateUtils';
import { format } from 'date-fns';

/**
 * Compact Calendar Widget for Dashboard
 *
 * Features:
 * - Shows current month in compact grid (30x30px cells)
 * - Event count indicators (colored dots on dates with events)
 * - Click date → navigate to full Calendar page
 * - Minimal design matching dashboard aesthetic
 * - No prev/next navigation (current month only)
 */
export const CalendarWidget: React.FC = () => {
  const navigate = useNavigate();
  const { events, currentDate } = useCalendarStore();

  // Get current month info
  const year = currentDate.getFullYear();
  const month = currentDate.getMonth();
  const firstDay = getFirstDayOfMonth(currentDate);
  const daysInMonth = getDaysInMonth(currentDate);
  const daysInPrevMonth = getDaysInPrevMonth(currentDate);

  // Calculate event counts per date for current month
  const eventCounts = useMemo(() => {
    const counts: Record<string, number> = {};

    // Only count events for current month
    for (let day = 1; day <= daysInMonth; day++) {
      const date = new Date(year, month, day);
      const dateKey = getLegacyDateKey(date);
      const dayEvents = events[dateKey] || [];
      if (dayEvents.length > 0) {
        counts[day] = dayEvents.length;
      }
    }

    return counts;
  }, [events, year, month, daysInMonth]);

  // Generate calendar grid (42 cells = 6 weeks max)
  const calendarDays: Array<{ day: number; isCurrentMonth: boolean; isToday: boolean }> = [];

  // Previous month's trailing days
  const prevMonthStart = daysInPrevMonth - firstDay + 1;
  for (let day = prevMonthStart; day <= daysInPrevMonth; day++) {
    calendarDays.push({ day, isCurrentMonth: false, isToday: false });
  }

  // Current month's days
  for (let day = 1; day <= daysInMonth; day++) {
    calendarDays.push({
      day,
      isCurrentMonth: true,
      isToday: isToday(new Date(year, month, day)),
    });
  }

  // Next month's leading days (fill to 42 cells)
  const remainingCells = 42 - calendarDays.length;
  for (let day = 1; day <= remainingCells; day++) {
    calendarDays.push({ day, isCurrentMonth: false, isToday: false });
  }

  // Handle date click → navigate to full calendar
  const handleDateClick = (day: number) => {
    if (day >= 1 && day <= daysInMonth) {
      navigate(`/calendar?date=${year}-${String(month + 1).padStart(2, '0')}-${String(day).padStart(2, '0')}`);
    }
  };

  return (
    <Widget
      id="calendarmini"
      title={format(currentDate, 'MMMM yyyy')}
      category="visual"
      className="calendar-widget"
    >
      <div className="px-3 py-2">
        {/* Week day headers */}
        <div className="grid grid-cols-7 gap-1 mb-2">
          {['Mo', 'Tu', 'We', 'Th', 'Fr', 'Sa', 'Su'].map((day) => (
            <div
              key={day}
              className="text-center text-[10px] font-medium text-text-light-secondary dark:text-text-dark-secondary"
            >
              {day}
            </div>
          ))}
        </div>

        {/* Calendar grid */}
        <div className="grid grid-cols-7 gap-1">
          {calendarDays.map((item, index) => {
            const hasEvents = item.isCurrentMonth && eventCounts[item.day] > 0;
            const eventCount = hasEvents ? eventCounts[item.day] : 0;

            return (
              <button
                key={index}
                onClick={() => item.isCurrentMonth && handleDateClick(item.day)}
                disabled={!item.isCurrentMonth}
                className={`
                  relative w-[30px] h-[30px] rounded text-xs font-medium
                  flex items-center justify-center
                  transition-all
                  ${
                    item.isCurrentMonth
                      ? 'text-text-light-primary dark:text-text-dark-primary cursor-pointer hover:bg-accent-blue/10 dark:hover:bg-accent-blue/20'
                      : 'text-text-light-secondary/40 dark:text-text-dark-secondary/40 cursor-not-allowed'
                  }
                  ${
                    item.isToday
                      ? 'bg-accent-blue text-white font-bold hover:bg-accent-blue-hover'
                      : ''
                  }
                `}
                title={hasEvents ? `${eventCount} event${eventCount > 1 ? 's' : ''}` : undefined}
              >
                {item.day}

                {/* Event indicator dot */}
                {hasEvents && !item.isToday && (
                  <div className="absolute bottom-0.5 left-1/2 transform -translate-x-1/2 w-1 h-1 rounded-full bg-accent-cyan"></div>
                )}
              </button>
            );
          })}
        </div>

        {/* Footer with link to full calendar */}
        <div className="mt-3 pt-2 border-t border-border-light dark:border-border-dark">
          <button
            onClick={() => navigate('/calendar')}
            className="text-xs text-accent-blue hover:text-accent-blue-hover transition-colors w-full text-center"
          >
            Open Full Calendar →
          </button>
        </div>
      </div>
    </Widget>
  );
};
