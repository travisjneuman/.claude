#!/usr/bin/env python3
"""
OneNote Conversion Script
Attempts to extract content from .one files using pyOneNote or direct parsing.
Since we don't have full pyOneNote support, we'll extract what we can and
create placeholder Markdown files with available metadata.
"""

import os
import struct
from pathlib import Path
from datetime import datetime
import json

# Configuration
BASE_PATH = Path(r"D:\Proton Drive\My files\Documents\Personal\Notebooks")
OUTPUT_DIR = BASE_PATH / "_converted"
MARKDOWN_DIR = OUTPUT_DIR / "markdown"
LOG_FILE = BASE_PATH / "_scripts" / "output" / "onenote_conversion_log.json"

def ensure_dirs():
    """Create output directories."""
    OUTPUT_DIR.mkdir(parents=True, exist_ok=True)
    MARKDOWN_DIR.mkdir(parents=True, exist_ok=True)

def sanitize_filename(name: str) -> str:
    """Sanitize filename for filesystem."""
    import re
    invalid_chars = '<>:"/\\|?*'
    for char in invalid_chars:
        name = name.replace(char, '_')
    name = re.sub(r'[_\s]+', ' ', name).strip()
    if len(name) > 200:
        name = name[:200]
    return name

def read_onenote_header(filepath: Path) -> dict:
    """Read basic header information from a OneNote file."""
    info = {
        'valid': False,
        'version': None,
        'size': filepath.stat().st_size,
        'filename': filepath.name,
    }

    try:
        with open(filepath, 'rb') as f:
            # Read first 16 bytes (guidFileType)
            header = f.read(16)

            # Check for OneNote signature
            # Standard OneNote files start with specific GUIDs
            if header[:4] == b'\xe4\x52\x5c\x7b':
                info['valid'] = True
                info['version'] = 'OneNote 2010-2016'

            # Try to read file format version
            f.seek(0)
            data = f.read(1024)

            # Look for readable strings in the file
            # OneNote files often contain UTF-16 encoded text
            try:
                # Try to find any readable title or content strings
                text_fragments = []
                i = 0
                while i < len(data) - 2:
                    # Look for potential UTF-16 LE strings
                    if data[i] != 0 and data[i+1] == 0:
                        # Found potential start of UTF-16 LE string
                        end = i + 2
                        while end < len(data) - 1:
                            if data[end] == 0 and data[end+1] == 0:
                                break
                            end += 2
                        try:
                            text = data[i:end].decode('utf-16-le', errors='ignore')
                            if len(text) > 3 and text.isprintable():
                                text_fragments.append(text.strip())
                        except:
                            pass
                        i = end
                    else:
                        i += 1

                if text_fragments:
                    info['text_fragments'] = text_fragments[:10]  # Keep first 10
            except:
                pass

    except Exception as e:
        info['error'] = str(e)

    return info

def try_pyonenote_extraction(filepath: Path) -> dict:
    """Try to use pyOneNote for extraction if available."""
    try:
        from pyOneNote.Main import OneDocment
        doc = OneDocment(str(filepath))
        return {
            'success': True,
            'method': 'pyOneNote',
            'content': str(doc),
        }
    except ImportError:
        return {
            'success': False,
            'error': 'pyOneNote not installed',
        }
    except Exception as e:
        return {
            'success': False,
            'error': str(e),
        }

def create_onenote_markdown(filepath: Path, header_info: dict, extraction: dict, output_path: Path):
    """Create a Markdown file for a OneNote document."""
    lines = []

    # YAML frontmatter
    lines.append('---')
    lines.append(f'title: "{filepath.stem}"')
    lines.append(f'source: onenote')
    lines.append(f'source_file: "{filepath.name}"')
    lines.append(f'file_size: {header_info["size"]}')
    if header_info.get('version'):
        lines.append(f'version: "{header_info["version"]}"')
    lines.append(f'converted: {datetime.now().isoformat()}')
    lines.append('---')
    lines.append('')

    # Title
    lines.append(f'# {filepath.stem}')
    lines.append('')

    # Status note
    if extraction.get('success'):
        lines.append('> **Note:** Content extracted from OneNote file.')
        lines.append('')
        lines.append('## Content')
        lines.append('')
        lines.append(extraction.get('content', '(No content extracted)'))
    else:
        lines.append('> **Note:** This is a OneNote file that could not be fully converted.')
        lines.append('> The original .one file is preserved for manual conversion if needed.')
        lines.append('')

        # Include any text fragments we found
        if header_info.get('text_fragments'):
            lines.append('## Detected Text Fragments')
            lines.append('')
            for fragment in header_info['text_fragments']:
                if len(fragment) > 5:  # Only include meaningful fragments
                    lines.append(f'- {fragment}')
            lines.append('')

    lines.append('')
    lines.append('## Conversion Notes')
    lines.append('')
    lines.append(f'- Original file: `{filepath.name}`')
    lines.append(f'- File size: {header_info["size"]:,} bytes')
    if extraction.get('error'):
        lines.append(f'- Conversion error: {extraction["error"]}')
    lines.append('')
    lines.append('### Manual Conversion Options')
    lines.append('')
    lines.append('1. Open the original .one file in Microsoft OneNote')
    lines.append('2. Export to PDF or HTML')
    lines.append('3. Convert exported file to Markdown using pandoc')
    lines.append('')

    # Write file
    output_path.parent.mkdir(parents=True, exist_ok=True)
    with open(output_path, 'w', encoding='utf-8') as f:
        f.write('\n'.join(lines))

def find_onenote_files() -> list:
    """Find all .one files in the notebooks folder."""
    files = []
    for root, dirs, filenames in os.walk(BASE_PATH):
        # Skip output directories
        if '_converted' in root or '_scripts' in root:
            continue
        for f in filenames:
            if f.endswith('.one'):
                files.append(Path(root) / f)
    return files

def main():
    print("=" * 60)
    print("OneNote Conversion Script")
    print("=" * 60)

    ensure_dirs()

    # Find all OneNote files
    files = find_onenote_files()
    print(f"\nFound {len(files)} OneNote files")

    if not files:
        print("No OneNote files to process!")
        return

    # Process each file
    log = {
        'processed': [],
        'errors': [],
        'stats': {
            'total': len(files),
            'success': 0,
            'partial': 0,
            'failed': 0,
        }
    }

    for i, one_path in enumerate(files):
        print(f"\r  Processing {i+1}/{len(files)}: {one_path.name[:50]}...", end='', flush=True)

        try:
            # Read header info
            header_info = read_onenote_header(one_path)

            # Try extraction
            extraction = try_pyonenote_extraction(one_path)

            # Create output path
            safe_name = sanitize_filename(one_path.stem)
            md_path = MARKDOWN_DIR / f"{safe_name} (OneNote).md"

            # Skip if already processed
            if md_path.exists():
                continue

            # Create Markdown file
            create_onenote_markdown(one_path, header_info, extraction, md_path)

            # Update stats
            if extraction.get('success'):
                log['stats']['success'] += 1
            elif header_info.get('text_fragments'):
                log['stats']['partial'] += 1
            else:
                log['stats']['failed'] += 1

            log['processed'].append({
                'source': str(one_path),
                'markdown': str(md_path),
                'valid': header_info.get('valid', False),
                'extracted': extraction.get('success', False),
            })

        except Exception as e:
            log['errors'].append({
                'file': str(one_path),
                'error': str(e),
            })

    print(f"\n\nWriting log to: {LOG_FILE}")
    with open(LOG_FILE, 'w', encoding='utf-8') as f:
        json.dump(log, f, indent=2)

    # Print summary
    print("\n" + "=" * 60)
    print("ONENOTE CONVERSION SUMMARY")
    print("=" * 60)
    print(f"Total files: {log['stats']['total']}")
    print(f"Fully extracted: {log['stats']['success']}")
    print(f"Partial extraction: {log['stats']['partial']}")
    print(f"Placeholder only: {log['stats']['failed']}")
    print(f"Errors: {len(log['errors'])}")
    print("\nNote: Full OneNote conversion requires pyOneNote library")
    print("      Install with: pip install pyOneNote")
    print("=" * 60)

if __name__ == '__main__':
    main()
