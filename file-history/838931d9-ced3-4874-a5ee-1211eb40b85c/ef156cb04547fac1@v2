### Change #6: Keyboard Shortcuts

**File:** `src/components/AITerminal.tsx`

**Add keyboard shortcuts:**
- `Ctrl+Shift+A` or `Cmd+Shift+A` - Toggle terminal
- `Escape` - Close terminal (when focused)

**Implementation:**
```tsx
useEffect(() => {
  const handleKeyDown = (e: KeyboardEvent) => {
    // Cmd/Ctrl + Shift + A to toggle
    if ((e.metaKey || e.ctrlKey) && e.shiftKey && e.key === 'a') {
      e.preventDefault();
      setOpen(!isOpen);
    }
    // Escape to close (when terminal is open)
    if (e.key === 'Escape' && isOpen) {
      setOpen(false);
    }
  };

  document.addEventListener('keydown', handleKeyDown);
  return () => document.removeEventListener('keydown', handleKeyDown);
}, [isOpen, setOpen]);
```

