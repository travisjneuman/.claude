#!/usr/bin/env python3
"""
Render Embedded PDFs from Notability Files
Extracts PDFs from .note files and renders each page as PNG.
These PDFs contain handwriting that was flattened/merged by Notability.
"""

import os
import zipfile
import json
import fitz  # PyMuPDF
from pathlib import Path
from concurrent.futures import ThreadPoolExecutor, as_completed

# Configuration
BASE_PATH = Path(r"D:\Proton Drive\My files\Documents\Personal\Notebooks")
OUTPUT_DIR = BASE_PATH / "_converted" / "pdf_rendered"
LOG_FILE = BASE_PATH / "_scripts" / "output" / "pdf_render_log.json"

# Render settings
DPI = 150  # Good balance of quality and file size
MAX_PAGES_PER_NOTE = 50  # Limit for very long documents


def sanitize_filename(name: str) -> str:
    """Sanitize filename for filesystem."""
    import re
    invalid_chars = '<>:"/\\|?*'
    for char in invalid_chars:
        name = name.replace(char, '_')
    name = re.sub(r'[_\s]+', ' ', name).strip()
    if len(name) > 150:
        name = name[:150]
    return name


def render_pdf_from_note(note_path: Path, output_dir: Path) -> dict:
    """Extract and render PDFs from a .note file."""
    result = {
        'source': str(note_path),
        'success': False,
        'pdfs_found': 0,
        'pages_rendered': 0,
        'outputs': [],
    }

    try:
        with zipfile.ZipFile(note_path, 'r') as z:
            # Find all PDFs in the archive
            pdf_files = [n for n in z.namelist() if n.endswith('.pdf')]
            result['pdfs_found'] = len(pdf_files)

            if not pdf_files:
                result['error'] = 'No PDFs found'
                return result

            safe_name = sanitize_filename(note_path.stem)
            note_output_dir = output_dir / safe_name
            note_output_dir.mkdir(parents=True, exist_ok=True)

            for pdf_name in pdf_files:
                pdf_data = z.read(pdf_name)

                try:
                    doc = fitz.open(stream=pdf_data, filetype='pdf')
                    page_count = min(doc.page_count, MAX_PAGES_PER_NOTE)

                    # Render each page
                    for page_num in range(page_count):
                        page = doc[page_num]

                        # Calculate scale for target DPI
                        zoom = DPI / 72  # PDF default is 72 DPI
                        matrix = fitz.Matrix(zoom, zoom)

                        # Render to pixmap
                        pix = page.get_pixmap(matrix=matrix)

                        # Save as PNG
                        if page_count == 1:
                            output_name = f"{safe_name}.png"
                        else:
                            output_name = f"{safe_name}_page{page_num + 1:03d}.png"

                        output_path = note_output_dir / output_name
                        pix.save(str(output_path))

                        result['outputs'].append(str(output_path))
                        result['pages_rendered'] += 1

                    doc.close()

                except Exception as e:
                    result['pdf_errors'] = result.get('pdf_errors', [])
                    result['pdf_errors'].append(f"{pdf_name}: {str(e)}")

            result['success'] = result['pages_rendered'] > 0

    except Exception as e:
        result['error'] = str(e)

    return result


def find_note_files() -> list:
    """Find all .note files."""
    files = []
    for root, dirs, filenames in os.walk(BASE_PATH):
        if '_converted' in root or '_scripts' in root or '_organized' in root:
            continue
        for f in filenames:
            if f.endswith('.note'):
                files.append(Path(root) / f)
    return files


def main():
    print("=" * 60)
    print("Render PDFs from Notability Files")
    print("(Extracts handwriting that was flattened into PDFs)")
    print("=" * 60)

    OUTPUT_DIR.mkdir(parents=True, exist_ok=True)

    # Get all note files
    files = find_note_files()
    print(f"\nFound {len(files)} .note files")

    log = {
        'processed': [],
        'with_pdfs': [],
        'no_pdfs': [],
        'errors': [],
        'stats': {
            'total': len(files),
            'with_pdfs': 0,
            'total_pages': 0,
            'errors': 0,
        }
    }

    for i, note_path in enumerate(files):
        if i % 50 == 0:
            print(f"\r  Processing {i+1}/{len(files)}...", end='', flush=True)

        result = render_pdf_from_note(note_path, OUTPUT_DIR)

        if result['success']:
            log['stats']['with_pdfs'] += 1
            log['stats']['total_pages'] += result['pages_rendered']
            log['with_pdfs'].append({
                'source': str(note_path),
                'pages': result['pages_rendered'],
                'outputs': result['outputs'][:3],  # First 3 for log size
            })
        elif result.get('error') == 'No PDFs found':
            log['no_pdfs'].append(str(note_path))
        else:
            log['stats']['errors'] += 1
            log['errors'].append({
                'source': str(note_path),
                'error': result.get('error', result.get('pdf_errors', 'Unknown')),
            })

    # Save log
    print(f"\n\nWriting log to: {LOG_FILE}")
    with open(LOG_FILE, 'w', encoding='utf-8') as f:
        json.dump(log, f, indent=2, default=str)

    print("\n" + "=" * 60)
    print("PDF RENDER RESULTS")
    print("=" * 60)
    print(f"Total .note files: {log['stats']['total']}")
    print(f"With embedded PDFs: {log['stats']['with_pdfs']}")
    print(f"Total pages rendered: {log['stats']['total_pages']}")
    print(f"No PDFs (images/text only): {len(log['no_pdfs'])}")
    print(f"Errors: {log['stats']['errors']}")
    print(f"\nRendered files saved to: {OUTPUT_DIR}")
    print("=" * 60)


if __name__ == '__main__':
    main()
