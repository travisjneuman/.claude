## Advanced Features

### Hooks (Middleware)

```typescript
db.notes.hook("creating", (primKey, obj, trans) => {
  obj.createdAt = new Date();
  obj.updatedAt = new Date();
});

db.notes.hook("updating", (mods, primKey, obj, trans) => {
  return { ...mods, updatedAt: new Date() };
});

db.notes.hook("deleting", (primKey, obj, trans) => {
  console.log("Deleting note:", primKey);
});
```

### Bulk Operations

```typescript
// Efficient bulk add
await db.notes.bulkAdd(notesArray);

// Bulk put (insert or update)
await db.notes.bulkPut(notesArray);

// Bulk delete
await db.notes.bulkDelete(idsArray);

// With error handling
const results = await db.notes.bulkAdd(notesArray, { allKeys: true });
```

### Export/Import

```typescript
// Export database
async function exportDB() {
  const notes = await db.notes.toArray();
  const folders = await db.folders.toArray();
  const tasks = await db.tasks.toArray();

  return JSON.stringify({ notes, folders, tasks });
}

// Import database
async function importDB(jsonString: string) {
  const data = JSON.parse(jsonString);

  await db.transaction("rw", db.notes, db.folders, db.tasks, async () => {
    await db.notes.clear();
    await db.folders.clear();
    await db.tasks.clear();

    await db.folders.bulkAdd(data.folders);
    await db.notes.bulkAdd(data.notes);
    await db.tasks.bulkAdd(data.tasks);
  });
}
```

