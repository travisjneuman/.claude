## Database Setup

### Define Schema

```typescript
// db/db.ts
import Dexie, { Table } from "dexie";

export interface Note {
  id?: number;
  title: string;
  content: string;
  createdAt: Date;
  updatedAt: Date;
  tags: string[];
  folderId?: number;
}

export interface Folder {
  id?: number;
  name: string;
  parentId?: number;
  createdAt: Date;
}

export interface Task {
  id?: number;
  title: string;
  completed: boolean;
  dueDate?: Date;
  noteId?: number;
  createdAt: Date;
}

export class AppDatabase extends Dexie {
  notes!: Table<Note, number>;
  folders!: Table<Folder, number>;
  tasks!: Table<Task, number>;

  constructor() {
    super("AppDatabase");

    this.version(1).stores({
      notes: "++id, title, createdAt, updatedAt, folderId, *tags",
      folders: "++id, name, parentId, createdAt",
      tasks: "++id, title, completed, dueDate, noteId, createdAt",
    });
  }
}

export const db = new AppDatabase();
```

### Index Syntax

```typescript
// Index definition syntax
this.version(1).stores({
  // ++id: Auto-incrementing primary key
  // id: Manual primary key
  // &email: Unique index
  // *tags: Multi-entry index (array)
  // [firstName+lastName]: Compound index

  users: "++id, &email, name, *roles, [firstName+lastName]",
  posts: "++id, authorId, createdAt, [authorId+createdAt]",
});
```

