## Schema Migrations

```typescript
export class AppDatabase extends Dexie {
  notes!: Table<Note, number>;

  constructor() {
    super("AppDatabase");

    // Version 1: Initial schema
    this.version(1).stores({
      notes: "++id, title, createdAt",
    });

    // Version 2: Add tags
    this.version(2).stores({
      notes: "++id, title, createdAt, *tags",
    });

    // Version 3: Add folderId with migration
    this.version(3)
      .stores({
        notes: "++id, title, createdAt, folderId, *tags",
      })
      .upgrade((tx) => {
        return tx
          .table("notes")
          .toCollection()
          .modify((note) => {
            note.folderId = null; // Set default for existing records
          });
      });
  }
}
```

