## Best Practices

### Do

```typescript
// 1. Use selectors for performance
const count = useStore((s) => s.count); // Good - selective

// 2. Keep actions in store
const store = create((set) => ({
  items: [],
  addItem: (item) => set((s) => ({ items: [...s.items, item] })),
}));

// 3. Use TypeScript interfaces
interface State {
  count: number;
  increment: () => void;
}

// 4. Split large stores into slices
```

### Don't

```typescript
// 1. Don't select entire store (causes re-renders)
const store = useStore(); // Bad - re-renders on any change

// 2. Don't mutate state directly
set((state) => {
  state.items.push(item); // Bad without immer
  return state;
});

// 3. Don't forget to handle async errors
fetchData: async () => {
  const data = await fetch(url); // Missing try/catch
  set({ data });
};
```

