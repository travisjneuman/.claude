### Change 4: Recommended Widget Sizes

**File:** `src/widgets/Dashboard/WidgetRegistry.ts`

Add `recommendedSize` metadata to help users choose optimal sizes:

```typescript
export interface WidgetMetadata {
  id: string;
  name: string;
  description: string;
  icon: string;
  category: WidgetCategory;
  apiUrl?: string;
  requiresAuth?: boolean;
  defaultEnabled?: boolean;
  recommendedSize?: 1 | 2 | 3; // NEW: Suggested size for this widget
}

export const WIDGET_REGISTRY: Record<string, WidgetMetadata> = {
  // Large data widgets → 2x-3x recommended
  weathermap: {
    id: 'weathermap',
    name: 'Weather & Map',
    description: 'Interactive weather map with current conditions & 5-day forecast',
    icon: '🗺️',
    category: 'visual',
    recommendedSize: 3, // NEW: Large map benefits from width
    defaultEnabled: true,
  },

  // Medium widgets → 2x recommended
  calendar: {
    id: 'calendar',
    name: 'Calendar',
    description: 'Monthly calendar with events',
    icon: '📅',
    category: 'productivity',
    recommendedSize: 2, // NEW: Month view needs space
    defaultEnabled: false,
  },

  // Small widgets → 1x (default)
  quote: {
    id: 'quote',
    name: 'Inspirational Quotes',
    description: 'Daily motivational quotes',
    icon: '💭',
    category: 'inspiration',
    recommendedSize: 1, // NEW: Text widget, compact
    defaultEnabled: true,
  },
};
```

**Usage:**
When adding widget, use `recommendedSize` as initial value instead of hardcoded `1`:

```typescript
addWidget: (id) => set((state) => {
  const metadata = WIDGET_REGISTRY[id];
  const initialSize = metadata?.recommendedSize || 1;

  return {
    enabledWidgets: [...state.enabledWidgets, id],
    widgetOrder: [...state.widgetOrder, id],
    widgetSizes: { ...state.widgetSizes, [id]: initialSize },
  };
}),
```

