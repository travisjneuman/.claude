## Implementation Plan

### Part 1: Subtasks Data Model & Store (4-6 hours)

**Goal:** Add subtask support to type system and store

**Files to Modify:**
1. `src/types/index.ts` - Add Subtask interface
2. `src/stores/useKanbanStore.ts` - Add subtask actions

**New Actions:**
- `addSubtask(taskId, subtask)` - Create subtask
- `updateSubtask(taskId, subtaskId, updates)` - Edit subtask
- `deleteSubtask(taskId, subtaskId)` - Remove subtask
- `toggleSubtask(taskId, subtaskId)` - Toggle completed
- `reorderSubtasks(taskId, subtaskIds)` - Manual sorting

**Implementation:**
```typescript
// src/types/index.ts
export interface Subtask {
  id: string;
  parentTaskId: string;
  title: string;
  description?: string;
  completed: boolean;
  priority?: TaskPriority;
  dueDate?: string;
  order: number;
  createdAt: Date;
  completedAt?: Date;
}

export interface Task {
  // ... existing fields
  subtasks: Subtask[]; // NEW
}

// src/stores/useKanbanStore.ts
addSubtask: (taskId: string, subtaskData: Omit<Subtask, 'id' | 'parentTaskId' | 'createdAt' | 'order'>) => {
  set((state) => ({
    tasks: state.tasks.map(task => {
      if (task.id === taskId) {
        const newSubtask: Subtask = {
          ...subtaskData,
          id: uuidv4(),
          parentTaskId: taskId,
          order: task.subtasks.length,
          createdAt: new Date(),
        };
        return {
          ...task,
          subtasks: [...task.subtasks, newSubtask]
        };
      }
      return task;
    })
  }));

  // Log activity
  get().logActivity(taskId, {
    action: 'created',
    field: 'subtask',
    newValue: subtaskData.title,
  });
},
```

