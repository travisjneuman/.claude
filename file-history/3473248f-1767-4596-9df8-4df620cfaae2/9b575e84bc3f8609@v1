#!/usr/bin/env python3
"""
Reorganize Converted Notes
Organizes converted Markdown files into topic-based folders and
moves cryptic/unclear filenames to .review/ for manual inspection.
"""

import os
import re
import json
import shutil
from pathlib import Path
from datetime import datetime

# Configuration
BASE_PATH = Path(r"D:\Proton Drive\My files\Documents\Personal\Notebooks")
CONVERTED_DIR = BASE_PATH / "_converted"
MARKDOWN_DIR = CONVERTED_DIR / "markdown"
OUTPUT_DIR = BASE_PATH / "_scripts" / "output"
REORG_LOG = OUTPUT_DIR / "reorganization_log.json"

# Target structure
ORGANIZED_DIR = BASE_PATH / "_organized"

# Category patterns (case-insensitive regex)
CATEGORY_PATTERNS = {
