#### 1.1 Fix Date Selection Bug (30 min)

**File:** `src/utils/dateUtils.ts`

**Current Code (Lines 27-32):**
```typescript
export function getLegacyDateKey(date: Date): string {
  const year = date.getFullYear();
  const month = date.getMonth();        // ❌ Returns 0-11
  const day = date.getDate();
  return `${year}-${month}-${day}`;     // ❌ "2025-0-15" for Jan 15
}
```

**Fix:**
```typescript
// Keep old function for reading legacy data
export function getLegacyDateKey(date: Date): string {
  const year = date.getFullYear();
  const month = date.getMonth();
  const day = date.getDate();
  return `${year}-${month}-${day}`;
}

// New function with correct 1-indexed month
export function getStandardDateKey(date: Date): string {
  const year = date.getFullYear();
  const month = date.getMonth() + 1;  // ✅ Convert to 1-indexed
  const day = date.getDate();

  // Pad month and day with leading zeros
  const paddedMonth = String(month).padStart(2, '0');
  const paddedDay = String(day).padStart(2, '0');

  return `${year}-${paddedMonth}-${paddedDay}`;  // "2025-01-15"
}
```

**File:** `src/stores/useCalendarStore.ts`

**Add migration script (insert after state interface, before create()):**
```typescript
// One-time migration: Convert legacy date keys (0-indexed month) to standard keys (1-indexed month)
function migrateLegacyDateKeys(events: Record<string, CalendarEvent[]>): Record<string, CalendarEvent[]> {
  const migratedEvents: Record<string, CalendarEvent[]> = {};
  let migrationCount = 0;

  for (const [oldKey, eventList] of Object.entries(events)) {
    // Parse old key format: "YYYY-M-D" (0-indexed month)
    const parts = oldKey.split('-');
    if (parts.length === 3) {
      const year = parseInt(parts[0], 10);
      const month = parseInt(parts[1], 10);  // 0-11
      const day = parseInt(parts[2], 10);

      // Create date and convert to standard key
      const date = new Date(year, month, day);
      const newKey = getStandardDateKey(date);  // "YYYY-MM-DD" (1-indexed month)

      if (oldKey !== newKey) {
        migratedEvents[newKey] = eventList;
        migrationCount++;
      } else {
        migratedEvents[oldKey] = eventList;
      }
    } else {
      // Keep non-standard keys as-is
      migratedEvents[oldKey] = eventList;
    }
  }

  if (migrationCount > 0) {
    console.log(`✅ Migrated ${migrationCount} calendar event keys to standard format`);
  }

  return migratedEvents;
}
```

