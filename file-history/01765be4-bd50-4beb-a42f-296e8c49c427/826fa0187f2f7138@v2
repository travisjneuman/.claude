## Proposed Changes

### Change 1: Add Widget Size to Store

**File:** `src/stores/useWidgetStore.ts`

**Current State:**
```typescript
interface WidgetStore {
  enabledWidgets: string[];
  widgetOrder: string[];
  addWidget: (id: string) => void;
  removeWidget: (id: string) => void;
  reorderWidgets: (newOrder: string[]) => void;
}
```

**Proposed State:**
```typescript
interface WidgetStore {
  enabledWidgets: string[];
  widgetOrder: string[];
  widgetSizes: Record<string, 1 | 2 | 3>; // NEW: Widget ID → size mapping
  addWidget: (id: string) => void;
  removeWidget: (id: string) => void;
  reorderWidgets: (newOrder: string[]) => void;
  setWidgetSize: (id: string, size: 1 | 2 | 3) => void; // NEW: Update widget size
}
```

**Implementation:**
```typescript
export const useWidgetStore = create<WidgetStore>()(
  persist(
    (set) => ({
      enabledWidgets: [],
      widgetOrder: [],
      widgetSizes: {}, // NEW: Default empty

      addWidget: (id) => set((state) => ({
        enabledWidgets: [...state.enabledWidgets, id],
        widgetOrder: [...state.widgetOrder, id],
        widgetSizes: { ...state.widgetSizes, [id]: 1 }, // NEW: Default to 1x
      })),

      removeWidget: (id) => set((state) => {
        const { [id]: _, ...remainingSizes } = state.widgetSizes;
        return {
          enabledWidgets: state.enabledWidgets.filter((w) => w !== id),
          widgetOrder: state.widgetOrder.filter((w) => w !== id),
          widgetSizes: remainingSizes, // NEW: Clean up size
        };
      }),

      reorderWidgets: (newOrder) => set({ widgetOrder: newOrder }),

      setWidgetSize: (id, size) => set((state) => ({ // NEW: Update size
        widgetSizes: { ...state.widgetSizes, [id]: size },
      })),
    }),
    {
      name: 'widget-config',
      version: 2, // NEW: Increment version for migration
    }
  )
);
```

**Migration Strategy:**
- Zustand persist middleware auto-migrates when version increments
- Existing users: `widgetSizes` defaults to `{}`
- New widgets: Default to 1x width
- No data loss

