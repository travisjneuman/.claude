## Proposed Solution

### Architecture: Event-Driven Rule Engine

```typescript
interface AutomationRule {
  id: string;
  name: string;
  description?: string;
  enabled: boolean;

  // TRIGGER
  trigger: {
    type: 'task.created' | 'task.moved' | 'task.updated' | 'task.completed' |
          'task.overdue' | 'task.tagged' | 'recurring.generated' | 'time.daily' | 'time.weekly';
    config?: Record<string, any>; // Trigger-specific config
  };

  // CONDITIONS (optional - AND logic)
  conditions?: Array<{
    field: 'status' | 'priority' | 'tags' | 'dueDate' | 'title' | 'description' | 'estimatedHours';
    operator: 'equals' | 'not_equals' | 'contains' | 'not_contains' | 'greater_than' | 'less_than' | 'is_set' | 'is_not_set';
    value: any;
  }>;

  // ACTIONS
  actions: Array<{
    type: 'move_task' | 'set_priority' | 'add_tag' | 'remove_tag' | 'set_status' |
          'add_comment' | 'archive' | 'delete' | 'set_due_date' | 'set_estimate' |
          'duplicate' | 'notify';
    config: Record<string, any>; // Action-specific config
    delay?: number; // Milliseconds to delay (for "after X days")
  }>;

  // METADATA
  created: string;
  lastRun?: string;
  runCount: number;
}
```

