## Queries

### Where Clauses

```typescript
// Equals
const notes = await db.notes.where("title").equals("My Note").toArray();

// Above/Below (range)
const recent = await db.notes
  .where("createdAt")
  .above(lastWeek)
  .toArray();

const old = await db.notes
  .where("createdAt")
  .below(lastYear)
  .toArray();

// Between
const range = await db.notes
  .where("createdAt")
  .between(startDate, endDate)
  .toArray();

// Starts with (string)
const matching = await db.notes
  .where("title")
  .startsWith("Project")
  .toArray();

// Any of (IN)
const byTags = await db.notes
  .where("tags")
  .anyOf(["work", "urgent"])
  .toArray();

// None of (NOT IN)
const excluded = await db.notes
  .where("tags")
  .noneOf(["archived", "deleted"])
  .toArray();
```

### Compound Queries

```typescript
// AND (using compound index)
const notes = await db.notes
  .where("[folderId+createdAt]")
  .between([folderId, startDate], [folderId, endDate])
  .toArray();

// OR
const notes = await db.notes
  .where("title")
  .equals("Note 1")
  .or("title")
  .equals("Note 2")
  .toArray();

// Filter (for complex conditions)
const notes = await db.notes
  .filter((note) => note.tags.includes("important") && note.content.length > 100)
  .toArray();
```

### Sorting & Pagination

```typescript
// Order by
const notes = await db.notes.orderBy("createdAt").toArray();

// Reverse order
const notes = await db.notes.orderBy("createdAt").reverse().toArray();

// Limit
const topNotes = await db.notes.orderBy("createdAt").reverse().limit(10).toArray();

// Offset (pagination)
const page = await db.notes
  .orderBy("createdAt")
  .reverse()
  .offset(pageNumber * pageSize)
  .limit(pageSize)
  .toArray();
```

