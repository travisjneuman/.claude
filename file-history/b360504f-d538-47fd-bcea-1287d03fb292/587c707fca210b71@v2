### Web App Integration Pseudocode

```typescript
// In Neuman Brain web app (e.g., src/services/bookmarkSync.ts)

export function initializeBookmarkSync() {
  window.addEventListener('message', async (event) => {
    // Validate origin
    if (event.origin !== window.location.origin) return;

    // Validate message structure
    if (event.data.source !== 'neuman-brain-extension') return;

    const { type, data } = event.data;

    switch (type) {
      case 'full_sync':
        await handleFullSync(data);
        break;
      case 'bookmark_created':
        await handleBookmarkCreated(data);
        break;
      case 'bookmark_removed':
        await handleBookmarkRemoved(data);
        break;
      case 'bookmark_updated':
        await handleBookmarkUpdated(data);
        break;
    }
  });
}

async function handleFullSync(bookmarks: Bookmark[]) {
  // Write to IndexedDB (Link Library store)
  const db = await openLinksDB();
  const tx = db.transaction('links', 'readwrite');
  const store = tx.objectStore('links');

  // Clear existing browser bookmarks (marked with source: 'browser')
  const existingKeys = await store.getAllKeys();
  for (const key of existingKeys) {
    const existing = await store.get(key);
    if (existing.source === 'browser') {
      await store.delete(key);
    }
  }

  // Add new bookmarks
  for (const bookmark of bookmarks) {
    await store.add({
      id: `browser-${bookmark.id}`,
      title: bookmark.title,
      url: bookmark.url,
      folder: bookmark.folder,
      dateAdded: bookmark.dateAdded,
      source: 'browser', // Mark as synced from browser
      tags: [], // Can be enhanced by user in NB
    });
  }

  await tx.done;

  // Update UI
  useLinkStore.getState().loadLinks();
}
