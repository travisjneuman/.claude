## Key Concepts

### Basic Animation

```tsx
import { motion } from 'framer-motion';

// Simple animate on mount
<motion.div
  initial={{ opacity: 0 }}
  animate={{ opacity: 1 }}
/>

// With transition config
<motion.div
  animate={{ x: 100 }}
  transition={{ type: "spring", stiffness: 100 }}
/>
```

### Variants

Orchestrate complex animations across multiple elements:

```tsx
const container = {
  hidden: { opacity: 0 },
  show: {
    opacity: 1,
    transition: {
      staggerChildren: 0.1
    }
  }
};

const item = {
  hidden: { y: 20, opacity: 0 },
  show: { y: 0, opacity: 1 }
};

<motion.ul variants={container} initial="hidden" animate="show">
  {items.map(i => (
    <motion.li key={i} variants={item}>{i}</motion.li>
  ))}
</motion.ul>
```

### Gestures

```tsx
// Hover
<motion.button whileHover={{ scale: 1.05 }}>
  Hover me
</motion.button>

// Tap
<motion.button whileTap={{ scale: 0.95 }}>
  Click me
</motion.button>

// Drag
<motion.div drag dragConstraints={{ left: 0, right: 300 }}>
  Drag me
</motion.div>
```

### Exit Animations

```tsx
import { AnimatePresence, motion } from 'framer-motion';

<AnimatePresence>
  {isVisible && (
    <motion.div
      initial={{ opacity: 0 }}
      animate={{ opacity: 1 }}
      exit={{ opacity: 0 }}
    >
      Content
    </motion.div>
  )}
</AnimatePresence>
```

### Layout Animations

Automatic transitions when element positions change:

```tsx
<motion.div layout>
  {/* Content that changes size/position */}
</motion.div>

// Shared layout animations
<motion.div layoutId="shared-element">
  {/* Same element across different states */}
</motion.div>
```

