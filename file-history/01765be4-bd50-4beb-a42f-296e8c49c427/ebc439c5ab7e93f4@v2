### Change 3: Make Navigation Reorganizable (Drag-Drop)

**Option A: Simple (localStorage only)**
- Add state for navigation order
- Load/save from localStorage
- Use @dnd-kit (already installed) for drag-drop
- Estimated time: 2-3 hours

**Option B: Advanced (with reset/defaults)**
- Same as Option A
- Add "Reset to Default" button
- Better UX with visual drag handles
- Estimated time: 4-5 hours

**Recommended:** Option A for now, upgrade to B later if needed

**Implementation:**

1. Create `useSidebarNavStore.ts` (new Zustand store)
```typescript
interface SidebarNavStore {
  navOrder: string[]; // ['/', '/notes', '/planning', '/tasks']
  setNavOrder: (order: string[]) => void;
  resetToDefault: () => void;
}

export const useSidebarNavStore = create<SidebarNavStore>()(
  persist(
    (set) => ({
      navOrder: ['/', '/notes', '/planning', '/tasks'], // default order
      setNavOrder: (order) => set({ navOrder: order }),
      resetToDefault: () => set({ navOrder: ['/', '/notes', '/planning', '/tasks'] }),
    }),
    { name: 'sidebar-nav-order' }
  )
);
```

2. Update Sidebar.tsx to use drag-drop
```typescript
import { DndContext, closestCenter, DragEndEvent } from '@dnd-kit/core';
import { SortableContext, verticalListSortingStrategy, useSortable } from '@dnd-kit/sortable';
import { CSS } from '@dnd-kit/utilities';

// Inside Sidebar component:
const navOrder = useSidebarNavStore((state) => state.navOrder);
const setNavOrder = useSidebarNavStore((state) => state.setNavOrder);

// Sort navigation items by saved order
const sortedNavigation = [...navigation].sort((a, b) => {
  return navOrder.indexOf(a.path) - navOrder.indexOf(b.path);
});

const handleDragEnd = (event: DragEndEvent) => {
  const { active, over } = event;
  if (over && active.id !== over.id) {
    const oldIndex = navOrder.indexOf(active.id as string);
    const newIndex = navOrder.indexOf(over.id as string);

    const newOrder = arrayMove(navOrder, oldIndex, newIndex);
    setNavOrder(newOrder);
  }
};

// Wrap navigation in DndContext:
<DndContext collisionDetection={closestCenter} onDragEnd={handleDragEnd}>
  <SortableContext items={navOrder} strategy={verticalListSortingStrategy}>
    <nav className="flex-1 overflow-y-auto py-4">
      <ul className="space-y-1 px-2">
        {sortedNavigation.map((item) => (
          <SortableNavItem key={item.path} item={item} />
        ))}
      </ul>
    </nav>
  </SortableContext>
</DndContext>
```

3. Create `SortableNavItem` component (extracted from current nav item)
```typescript
const SortableNavItem: React.FC<{ item: NavItem }> = ({ item }) => {
  const { attributes, listeners, setNodeRef, transform, transition } = useSortable({ id: item.path });
  const style = {
    transform: CSS.Transform.toString(transform),
    transition,
  };

  return (
    <li ref={setNodeRef} style={style} {...attributes} {...listeners}>
      <Link to={item.path} ...>
        {/* existing nav item content */}
      </Link>
    </li>
  );
};
```

