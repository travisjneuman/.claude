## Widget Templates

### Template 1: Simple List Widget

Use for: Tasks, Notes, Events, Recent Activity

```tsx
import React from 'react';

interface SimpleListWidgetProps {
  title: string;
  count?: number;
  items: Array<{ id: string; content: React.ReactNode }>;
  actionLabel: string;
  onActionClick: () => void;
  accentColor: 'blue' | 'magenta' | 'cyan';
}

export const SimpleListWidget: React.FC<SimpleListWidgetProps> = ({
  title,
  count,
  items,
  actionLabel,
  onActionClick,
  accentColor,
}) => {
  const accentClass = `bg-accent-${accentColor}`;
  const accentHoverClass = `hover:bg-accent-${accentColor}-hover`;

  return (
    <div className="p-4 bg-surface-light dark:bg-surface-dark rounded-card shadow-card">
      <div className="space-y-4">
        {/* Header */}
        <section>
          <h3 className="text-sm font-semibold text-text-light-primary dark:text-text-dark-primary mb-2">
            {title} {count !== undefined && `(${count})`}
          </h3>

          {/* List */}
          {items.length > 0 ? (
            <ul className="space-y-3">
              {items.map((item) => (
                <li key={item.id}>
                  {item.content}
                </li>
              ))}
            </ul>
          ) : (
            <p className="text-xs text-text-light-secondary dark:text-text-dark-secondary">
              No items yet
            </p>
          )}
        </section>

        {/* Action Button */}
        <button
          onClick={onActionClick}
          className={`w-full px-4 py-2 rounded-lg ${accentClass} ${accentHoverClass} text-white font-medium transition-colors`}
        >
          {actionLabel}
        </button>
      </div>
    </div>
  );
};
```

**Usage:**
```tsx
<SimpleListWidget
  title="Tasks"
  count={3}
  items={[
    { id: '1', content: <TaskItem task={task1} /> },
    { id: '2', content: <TaskItem task={task2} /> },
    { id: '3', content: <TaskItem task={task3} /> },
  ]}
  actionLabel="View All Tasks"
  onActionClick={() => navigate('/tasks')}
  accentColor="blue"
/>
```

