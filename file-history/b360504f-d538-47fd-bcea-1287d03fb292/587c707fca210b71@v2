## Technical Implementation Details

### Extension Manifest (Manifest V3)

```json
{
  "manifest_version": 3,
  "name": "Neuman Brain Bookmark Sync",
  "version": "1.0.0",
  "description": "Sync your browser bookmarks with Neuman Brain locally",
  "permissions": [
    "bookmarks",
    "storage"
  ],
  "host_permissions": [
    "https://neuman.dev/*",
    "http://localhost:*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [{
    "matches": ["https://neuman.dev/*", "http://localhost:*"],
    "js": ["content.js"],
    "run_at": "document_idle"
  }],
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
```

### Background Worker Pseudocode

```javascript
// background.js (service worker)

// Full sync on extension install
chrome.runtime.onInstalled.addListener(async () => {
  await performFullSync();
  schedulePeriodicSync();
});

// Listen for bookmark events
chrome.bookmarks.onCreated.addListener((id, bookmark) => {
  sendToNeumanBrain({ type: 'bookmark_created', data: bookmark });
});

chrome.bookmarks.onRemoved.addListener((id, removeInfo) => {
  sendToNeumanBrain({ type: 'bookmark_removed', data: { id } });
});

chrome.bookmarks.onChanged.addListener((id, changeInfo) => {
  sendToNeumanBrain({ type: 'bookmark_updated', data: { id, ...changeInfo } });
});

// Periodic full sync (every 5 minutes)
function schedulePeriodicSync() {
  setInterval(performFullSync, 5 * 60 * 1000);
}

async function performFullSync() {
  const tree = await chrome.bookmarks.getTree();
  const flatBookmarks = flattenTree(tree);
  sendToNeumanBrain({ type: 'full_sync', data: flatBookmarks });
}

function flattenTree(nodes, parentPath = []) {
  let bookmarks = [];
  for (const node of nodes) {
    if (node.url) {
      bookmarks.push({
        id: node.id,
        title: node.title,
        url: node.url,
        folder: parentPath.join(' / '),
        dateAdded: node.dateAdded,
      });
    }
    if (node.children) {
      bookmarks.push(...flattenTree(node.children, [...parentPath, node.title]));
    }
  }
  return bookmarks;
}

async function sendToNeumanBrain(message) {
  const tabs = await chrome.tabs.query({ url: 'https://neuman.dev/*' });
  for (const tab of tabs) {
    chrome.tabs.sendMessage(tab.id, message);
  }
}
