### Auto-Escalate Overdue High Priority
```typescript
{
  name: "Move overdue high-priority tasks to urgent",
  trigger: { type: 'task.overdue' },
  conditions: [
    { field: 'priority', operator: 'equals', value: 'high' }
  ],
  actions: [
    { type: 'move_task', config: { status: 'todo' } },
    { type: 'add_tag', config: { tag: 'urgent' } },
    { type: 'add_comment', config: { text: 'Auto-escalated due to overdue + high priority' } }
  ]
}
```

