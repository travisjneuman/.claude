#### Task 1.2: Create Migration Utility (4 hours)
**File:** `src/services/migration.ts` (already exists? check first)

```typescript
// src/services/migration.ts
import { indexedDBService } from './indexedDB';

export interface MigrationResult {
  success: boolean;
  migratedKeys: string[];
  errors: string[];
}

/**
 * Migrate all data from localStorage to IndexedDB
 */
export async function migrateLocalStorageToIndexedDB(): Promise<MigrationResult> {
  const result: MigrationResult = {
    success: true,
    migratedKeys: [],
    errors: [],
  };

  try {
    console.log('🔄 Starting localStorage → IndexedDB migration...');

    // Get all localStorage keys
    const keys = Object.keys(localStorage);
    console.log(`Found ${keys.length} keys in localStorage`);

    for (const key of keys) {
      try {
        const value = localStorage.getItem(key);
        if (value === null) continue;

        // Write to IndexedDB
        await indexedDBService.setItem(key, value);
        result.migratedKeys.push(key);
        console.log(`✅ Migrated: ${key}`);
      } catch (error) {
        console.error(`❌ Failed to migrate ${key}:`, error);
        result.errors.push(`${key}: ${error}`);
        result.success = false;
      }
    }

    // Mark migration as complete
    await indexedDBService.setItem('__migration_completed', 'true');
    console.log(`✅ Migration complete: ${result.migratedKeys.length} keys migrated`);

    return result;
  } catch (error) {
    console.error('Migration failed:', error);
    result.success = false;
    result.errors.push(String(error));
    return result;
  }
}

/**
 * Check if migration has already been run
 */
export async function isMigrationComplete(): Promise<boolean> {
  const completed = await indexedDBService.getItem('__migration_completed');
  return completed === 'true';
}

/**
 * Clear localStorage after successful migration (optional, use with caution)
 */
export function clearLocalStorageAfterMigration(): void {
  console.warn('🗑️ Clearing localStorage (migration complete)');
  localStorage.clear();
}
```

