## Testing

### pytest Basics

```python
import pytest
from typing import List

# Basic test
def test_addition():
    assert 1 + 1 == 2

# Fixtures
@pytest.fixture
def sample_users() -> List[dict]:
    return [
        {"id": "1", "name": "Alice"},
        {"id": "2", "name": "Bob"},
    ]

def test_with_fixture(sample_users: List[dict]):
    assert len(sample_users) == 2

