## How Feature Gating Works Technically

### Client-Side Feature Flags

```typescript
// src/services/subscriptions.ts

export type SubscriptionTier = 'free' | 'pro' | 'enterprise';

export interface UserSubscription {
  tier: SubscriptionTier;
  expiresAt?: Date;
  features: string[];
}

// Feature flags
export const FEATURES = {
  // Always free
  NOTES_BASIC: 'notes_basic',
  TASKS: 'tasks',
  CALENDAR: 'calendar',
  TIME_TRACKING_BASIC: 'time_tracking_basic',
  HABITS: 'habits',
  ENCRYPTION: 'encryption',
  
  // Pro tier
  GRAPH_VIEW: 'graph_view',
  ADVANCED_SEARCH: 'advanced_search',
  REAL_TIME_COLLAB: 'real_time_collab',
  INTEGRATIONS: 'integrations',
  BILLABLE_HOURS: 'billable_hours',
  
  // Enterprise tier
  TEAM_MANAGEMENT: 'team_management',
  AUDIT_LOGS: 'audit_logs',
  SSO: 'sso',
  SELF_HOSTED: 'self_hosted',
} as const;

// Check if user has access to feature
export function hasFeature(feature: string): boolean {
  const subscription = getUserSubscription();
  
  // Always allow free features
  const freeFeatures = [
    FEATURES.NOTES_BASIC,
    FEATURES.TASKS,
    FEATURES.CALENDAR,
    FEATURES.TIME_TRACKING_BASIC,
    FEATURES.HABITS,
    FEATURES.ENCRYPTION,
  ];
  
  if (freeFeatures.includes(feature)) {
    return true;
  }
  
  // Check tier
  if (subscription.tier === 'free') {
    return false;
  }
  
  if (subscription.tier === 'pro' && PRO_FEATURES.includes(feature)) {
    return true;
  }
  
  if (subscription.tier === 'enterprise') {
    return true; // Enterprise gets everything
  }
  
  return false;
}

// Get user subscription (from local storage or server)
function getUserSubscription(): UserSubscription {
  // For now, everyone is free tier
  // Later: check localStorage for license key or call server
  const tier = localStorage.getItem('subscription_tier') || 'free';
  
  return {
    tier: tier as SubscriptionTier,
    features: [],
  };
}
```

### Usage in Components

```typescript
// src/components/GraphView.tsx

import { hasFeature, FEATURES } from '../services/subscriptions';

export function GraphView() {
  const hasAccess = hasFeature(FEATURES.GRAPH_VIEW);
  
  if (!hasAccess) {
    return (
      <div className="upgrade-prompt">
        <h3>📊 Graph View (Pro)</h3>
        <p>Visualize connections between your notes.</p>
        <button onClick={handleUpgrade}>
          Upgrade to Pro - $7/month
        </button>
      </div>
    );
  }
  
  // Render actual graph view
  return <GraphViewComponent />;
}
```

### License Validation (Privacy-Respecting)

**Option 1: Local License Keys (Recommended)**
```typescript
// User buys Pro → Gets license key: NBRAIN-PRO-XXXX-XXXX-XXXX
// Stores in localStorage
// App validates locally (offline-first)

export function validateLicense(key: string): SubscriptionTier {
  // Simple format validation
  if (key.startsWith('NBRAIN-PRO-')) {
    return 'pro';
  }
  if (key.startsWith('NBRAIN-ENT-')) {
    return 'enterprise';
  }
  return 'free';
}
```

**Option 2: Server Validation (For Collaboration Features)**
```typescript
// Only for features that REQUIRE server (real-time collab)
// Validates license against server
// Still works offline for local features

export async function validateLicenseWithServer(key: string): Promise<boolean> {
  try {
    const response = await fetch('https://brain.neuman.dev/api/validate', {
      method: 'POST',
      body: JSON.stringify({ key }),
    });
    return response.ok;
  } catch {
    // Offline: allow if key format is valid
    return validateLicense(key) !== 'free';
  }
}
```

