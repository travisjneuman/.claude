/**
 * Website Analytics Widget
 * Simple analytics tracker for website performance
 */

import React, { useState } from 'react';
import { BaseWidget } from './BaseWidget';
import { useWidgetStore } from '../../stores/useWidgetStore';

interface AnalyticsWidgetProps {
  widgetId?: string;
}

export const AnalyticsWidget: React.FC<AnalyticsWidgetProps> = ({ widgetId = 'analytics' }) => {
  const websites = useWidgetStore((state) => state.widgetSettings[widgetId]?.websites) || [];
  const updateWidgetSettings = useWidgetStore((state) => state.updateWidgetSettings);
  const [input, setInput] = useState('');

  const addWebsite = () => {
    if (input.trim()) {
      updateWidgetSettings(widgetId, { websites: [...websites, { url: input.trim(), visits: 0 }] });
      setInput('');
    }
  };

  const removeWebsite = (url: string) => {
    updateWidgetSettings(widgetId, { websites: websites.filter((w: any) => w.url !== url) });
  };

  return (
    <BaseWidget title="Analytics" icon="📈">
      <div className="space-y-3">
        <div className="flex gap-2">
          <input
            type="url"
            value={input}
            onChange={(e) => setInput(e.target.value)}
            onKeyPress={(e) => e.key === 'Enter' && addWebsite()}
            placeholder="Website URL..."
            className="flex-1 px-3 py-2 text-sm rounded-button bg-surface-light dark:bg-surface-dark border border-border-light dark:border-border-dark text-text-light-primary dark:text-text-dark-primary focus:ring-2 focus:ring-accent-blue transition-all duration-standard ease-smooth"
          />
          <button onClick={addWebsite} className="px-4 py-2 bg-accent-blue hover:bg-accent-blue-hover text-white rounded-button text-sm font-medium transition-all duration-standard ease-smooth">
            Add
          </button>
        </div>

        <div className="space-y-2">
          {websites.map((website: any, idx: number) => (
            <div key={idx} className="p-2 bg-surface-light-elevated dark:bg-surface-dark rounded-button transition-all duration-standard ease-smooth">
              <div className="flex items-center justify-between mb-1">
                <a href={website.url} target="_blank" rel="noopener noreferrer" className="text-sm text-text-light-primary dark:text-text-dark-primary hover:text-accent-blue truncate">
                  {website.url}
                </a>
                <button onClick={() => removeWebsite(website.url)} className="text-xs text-status-error hover:underline ml-2">
                  Remove
                </button>
              </div>
              <div className="text-xs text-text-light-secondary dark:text-text-dark-secondary">
                Connect Google Analytics to track metrics
              </div>
            </div>
          ))}
        </div>

        {websites.length === 0 && (
          <p className="text-sm text-text-light-secondary dark:text-text-dark-secondary text-center py-4">
            Add websites to track analytics
          </p>
        )}
      </div>
    </BaseWidget>
  );
};
