#!/usr/bin/env python3
"""
Duplicate Analysis Script
Groups files by base name, compares versions, and identifies duplicates.
Generates JSON report with recommendations for which version to keep.
"""

import os
import re
import json
import csv
from pathlib import Path
from collections import defaultdict
from datetime import datetime

# Configuration
BASE_PATH = Path(r"D:\Proton Drive\My files\Documents\Personal\Notebooks")
OUTPUT_DIR = BASE_PATH / "_scripts" / "output"
INPUT_CSV = OUTPUT_DIR / "inventory.csv"
OUTPUT_JSON = OUTPUT_DIR / "duplicates.json"
OUTPUT_SUMMARY = OUTPUT_DIR / "duplicates_summary.txt"

def load_inventory():
    """Load inventory from CSV file."""
    records = []
    with open(INPUT_CSV, 'r', encoding='utf-8') as f:
        reader = csv.DictReader(f)
        for row in reader:
            # Convert numeric fields
            row['size_bytes'] = int(row['size_bytes'])
            row['session_size'] = int(row['session_size']) if row['session_size'] else 0
            row['internal_files'] = int(row['internal_files']) if row['internal_files'] else 0
            row['pdf_count'] = int(row['pdf_count']) if row['pdf_count'] else 0
            row['image_count'] = int(row['image_count']) if row['image_count'] else 0
            row['has_recording'] = row['has_recording'] == 'True'
            records.append(row)
    return records

def get_base_name(filename: str) -> str:
    """
    Extract base name by removing duplicate suffixes.
    Examples:
        'file (2).note' -> 'file'
        'file (copy).note' -> 'file'
        'file(1).note' -> 'file'
        'file 1.note' -> 'file 1' (keep numbered if not in parens)
    """
    # Remove extension
    name = Path(filename).stem

    # Remove various duplicate patterns
    patterns = [
        r'\s*\(\d+\)\s*$',           # (2), (10), etc.
        r'\s*\(copy\)\s*$',          # (copy)
        r'\s*copy\s*$',              # copy
        r'\s*\(\d+\)\s*\(\d+\)\s*$', # (2) (2)
        r'\s*\(copy\)\s*\(\d+\)\s*$', # (copy) (2)
        r'\(\d+\)$',                 # (1) without space
    ]

    for pattern in patterns:
        name = re.sub(pattern, '', name, flags=re.IGNORECASE)

    return name.strip()

def score_version(record: dict) -> tuple:
    """
    Score a version to determine which is 'best'.
    Higher score = better version.
    Returns tuple for consistent ordering.
    """
    # Factors that indicate a better version:
    # 1. More internal files (more content)
    # 2. Larger session size (more note content)
    # 3. More images/PDFs embedded
    # 4. Has recordings
    # 5. Larger total size
    # 6. Cleaner filename (no suffixes)

    filename = record['filename']
    has_suffix = bool(re.search(r'\(\d+\)|\(copy\)', filename, re.IGNORECASE))

    return (
        record['internal_files'],     # More internal files is better
        record['session_size'],       # Larger session is better
        record['image_count'],        # More images is better
        record['pdf_count'],          # More PDFs is better
        1 if record['has_recording'] else 0,  # Has recording is better
        record['size_bytes'],         # Larger file is generally better
        0 if has_suffix else 1,       # Clean name is better
    )

def analyze_duplicates(records: list) -> dict:
    """Analyze records and group duplicates."""

    # Group by base name
    groups = defaultdict(list)
    for record in records:
        base = get_base_name(record['filename'])
        groups[base].append(record)

    # Analyze each group
    results = {
        'stats': {
            'total_files': len(records),
            'unique_base_names': len(groups),
            'groups_with_duplicates': 0,
            'byte_identical_groups': 0,
            'version_variant_groups': 0,
            'space_savings_identical': 0,
            'files_to_review': 0,
        },
        'byte_identical': [],      # Groups where all files have same hash
        'version_variants': [],    # Groups where files differ
        'unique_files': [],        # Files with no duplicates
    }

    for base_name, files in groups.items():
        if len(files) == 1:
            # No duplicates
            results['unique_files'].append({
                'base_name': base_name,
                'file': files[0]['path'],
                'size': files[0]['size_bytes'],
            })
            continue

        results['stats']['groups_with_duplicates'] += 1

        # Check if all files have the same hash
        hashes = set(f['hash'] for f in files if f['hash'] and f['hash'] != 'ERROR')
        all_identical = len(hashes) == 1 and len(hashes) > 0

        if all_identical:
            results['stats']['byte_identical_groups'] += 1

            # Sort by score to find best version
            sorted_files = sorted(files, key=score_version, reverse=True)
            keep = sorted_files[0]
            remove = sorted_files[1:]

            # Calculate space savings
            savings = sum(f['size_bytes'] for f in remove)
            results['stats']['space_savings_identical'] += savings

            results['byte_identical'].append({
                'base_name': base_name,
                'hash': list(hashes)[0][:16] + '...',
                'count': len(files),
                'recommendation': 'KEEP',
                'keep': {
                    'path': keep['path'],
                    'filename': keep['filename'],
                    'size': keep['size_bytes'],
                },
                'remove': [{
                    'path': f['path'],
                    'filename': f['filename'],
                    'size': f['size_bytes'],
                } for f in remove],
                'space_savings': savings,
            })
        else:
            results['stats']['version_variant_groups'] += 1
            results['stats']['files_to_review'] += len(files)

            # Sort by score - best version first
            sorted_files = sorted(files, key=score_version, reverse=True)

            results['version_variants'].append({
                'base_name': base_name,
                'count': len(files),
                'recommendation': 'REVIEW',
                'unique_hashes': len(hashes),
                'versions': [{
                    'path': f['path'],
                    'filename': f['filename'],
                    'size': f['size_bytes'],
                    'hash': f['hash'][:16] + '...' if f['hash'] else 'N/A',
                    'internal_files': f['internal_files'],
                    'session_size': f['session_size'],
                    'image_count': f['image_count'],
                    'pdf_count': f['pdf_count'],
                    'has_recording': f['has_recording'],
                    'score': sum(score_version(f)),
                    'is_recommended': f == sorted_files[0],
                } for f in sorted_files],
            })

    return results

def write_summary(results: dict, output_path: Path):
    """Write human-readable summary."""
    with open(output_path, 'w', encoding='utf-8') as f:
        f.write("=" * 70 + "\n")
        f.write("DUPLICATE ANALYSIS SUMMARY\n")
        f.write("=" * 70 + "\n\n")

        stats = results['stats']
        f.write(f"Total files analyzed: {stats['total_files']}\n")
        f.write(f"Unique base names: {stats['unique_base_names']}\n")
        f.write(f"Groups with duplicates: {stats['groups_with_duplicates']}\n\n")

        f.write("-" * 70 + "\n")
        f.write("BYTE-IDENTICAL DUPLICATES (Safe to auto-dedupe)\n")
        f.write("-" * 70 + "\n")
        f.write(f"Groups: {stats['byte_identical_groups']}\n")
        f.write(f"Potential space savings: {stats['space_savings_identical'] / (1024*1024):.2f} MB\n\n")

        f.write("-" * 70 + "\n")
        f.write("VERSION VARIANTS (Require manual review)\n")
        f.write("-" * 70 + "\n")
        f.write(f"Groups: {stats['version_variant_groups']}\n")
        f.write(f"Files to review: {stats['files_to_review']}\n\n")

        # List top version variant groups by file count
        f.write("-" * 70 + "\n")
        f.write("TOP VERSION VARIANT GROUPS (by file count)\n")
        f.write("-" * 70 + "\n")

        sorted_variants = sorted(results['version_variants'],
                                  key=lambda x: x['count'], reverse=True)

        for group in sorted_variants[:20]:
            f.write(f"\n{group['base_name']} ({group['count']} versions, {group['unique_hashes']} unique)\n")
            for v in group['versions'][:5]:
                marker = " [RECOMMENDED]" if v['is_recommended'] else ""
                f.write(f"  - {v['filename']}: {v['size']//1024}KB, "
                       f"{v['internal_files']} files, "
                       f"{v['image_count']} imgs{marker}\n")
            if len(group['versions']) > 5:
                f.write(f"  ... and {len(group['versions']) - 5} more\n")

        f.write("\n" + "=" * 70 + "\n")
        f.write("NEXT STEPS\n")
        f.write("=" * 70 + "\n")
        f.write("1. Review byte-identical duplicates - safe to keep recommended version\n")
        f.write("2. Examine version variants - use HTML review report for visual comparison\n")
        f.write("3. For each variant group, decide which version(s) to keep\n")

    print(f"  Written: {output_path}")

def main():
    print("=" * 60)
    print("Duplicate Analysis Script")
    print("=" * 60)

    # Check for inventory
    if not INPUT_CSV.exists():
        print(f"ERROR: Inventory not found at {INPUT_CSV}")
        print("Please run 02_inventory.py first.")
        return

    print(f"\nLoading inventory from: {INPUT_CSV}")
    records = load_inventory()
    print(f"  Loaded {len(records)} records")

    print("\nAnalyzing duplicates...")
    results = analyze_duplicates(records)

    print("\nWriting output files...")
    with open(OUTPUT_JSON, 'w', encoding='utf-8') as f:
        json.dump(results, f, indent=2)
    print(f"  Written: {OUTPUT_JSON}")

    write_summary(results, OUTPUT_SUMMARY)

    # Print summary
    stats = results['stats']
    print("\n" + "=" * 60)
    print("ANALYSIS SUMMARY")
    print("=" * 60)
    print(f"Total files: {stats['total_files']}")
    print(f"Unique base names: {stats['unique_base_names']}")
    print(f"Groups with duplicates: {stats['groups_with_duplicates']}")
    print(f"\nByte-identical groups: {stats['byte_identical_groups']}")
    print(f"  -> Safe to dedupe, saves {stats['space_savings_identical'] / (1024*1024):.2f} MB")
    print(f"\nVersion variant groups: {stats['version_variant_groups']}")
    print(f"  -> {stats['files_to_review']} files need manual review")
    print(f"\nUnique files (no duplicates): {len(results['unique_files'])}")
    print("=" * 60)

if __name__ == '__main__':
    main()
