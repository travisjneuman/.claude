---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

// Get featured available properties
const allProperties = await getCollection('properties');
const featuredProperties = allProperties
  .filter((p) => p.data.status === 'available' && p.data.featured)
  .slice(0, 3);
const availableCount = allProperties.filter((p) => p.data.status === 'available').length;
---

<BaseLayout
  title="Home"
  description="Find your next rental home with OakStone Properties. Browse our available apartments and houses."
>
  <!-- Hero Section -->
  <section class="gradient-primary text-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 md:py-24">
      <div class="max-w-3xl">
        <h1 class="text-4xl md:text-5xl font-bold mb-4">
          Find Your Next Home
        </h1>
        <p class="text-xl text-primary-100 mb-8">
          Quality rental properties managed with care. Browse our available homes and find the perfect place for you.
        </p>
        <div class="flex flex-col sm:flex-row gap-4">
          <a
            href="/properties"
            class="inline-flex items-center justify-center px-6 py-3 bg-white text-primary-700 font-semibold rounded-lg hover:bg-primary-50 transition-colors touch-target"
          >
            View All Properties
            <svg class="w-5 h-5 ml-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
            </svg>
          </a>
          <a
            href="/contact"
            class="inline-flex items-center justify-center px-6 py-3 border-2 border-white text-white font-semibold rounded-lg hover:bg-white/10 transition-colors touch-target"
          >
            Contact Us
          </a>
        </div>
        {availableCount > 0 && (
          <p class="mt-6 text-primary-200">
            <span class="font-semibold text-white">{availableCount}</span> properties currently available
          </p>
        )}
      </div>
    </div>
  </section>

  <!-- Featured Properties -->
  {featuredProperties.length > 0 && (
    <section class="py-16 bg-theme-primary">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-12">
          <h2 class="text-3xl font-bold text-theme-primary mb-4">Featured Properties</h2>
          <p class="text-lg text-theme-secondary max-w-2xl mx-auto">
            Check out some of our best available rentals
          </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
          {featuredProperties.map((property) => (
            <article class="property-card rounded-xl overflow-hidden shadow-md border border-theme-primary">
              <!-- Property Image -->
              <div class="aspect-video bg-theme-tertiary relative">
                <img
                  src={property.data.photos[0]}
                  alt={`Photo of ${property.data.title}`}
                  class="w-full h-full object-cover"
                  loading="lazy"
                />
                <span class="absolute top-3 left-3 badge-available px-3 py-1 rounded-full text-sm font-medium">
                  Available
                </span>
              </div>

              <!-- Property Details -->
              <div class="p-5">
                <h3 class="text-lg font-semibold text-theme-primary mb-2">
                  <a href={`/properties/${property.slug}`} class="hover:text-primary-600 transition-colors">
                    {property.data.title}
                  </a>
                </h3>

                <p class="text-theme-secondary text-sm mb-3">
                  {property.data.neighborhood}, {property.data.city}
                </p>

                <div class="flex items-center gap-4 text-sm text-theme-tertiary mb-4">
                  <span class="flex items-center gap-1">
                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
                    </svg>
                    {property.data.beds} bed
                  </span>
                  <span class="flex items-center gap-1">
                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 14v3m4-3v3m4-3v3M3 21h18M3 10h18M3 7l9-4 9 4M4 10h16v11H4V10z" />
                    </svg>
                    {property.data.baths} bath
                  </span>
                  {property.data.sqft && (
                    <span class="flex items-center gap-1">
                      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 8V4m0 0h4M4 4l5 5m11-1V4m0 0h-4m4 0l-5 5M4 16v4m0 0h4m-4 0l5-5m11 5l-5-5m5 5v-4m0 4h-4" />
                      </svg>
                      {property.data.sqft} sqft
                    </span>
                  )}
                </div>

                <div class="flex items-center justify-between pt-4 border-t border-theme-primary">
                  <p class="text-xl font-bold text-primary-600">
                    ${property.data.rent.toLocaleString()}<span class="text-sm font-normal text-theme-tertiary">/mo</span>
                  </p>
                  <a
                    href={`/properties/${property.slug}`}
                    class="text-sm font-medium text-primary-600 hover:text-primary-700 transition-colors"
                  >
                    View Details &rarr;
                  </a>
                </div>
              </div>
            </article>
          ))}
        </div>

        <div class="text-center mt-12">
          <a
            href="/properties"
            class="inline-flex items-center justify-center px-6 py-3 bg-primary-600 text-white font-semibold rounded-lg hover:bg-primary-700 transition-colors touch-target"
          >
            View All Properties
          </a>
        </div>
      </div>
    </section>
  )}

  <!-- Why Choose Us -->
  <section class="py-16 bg-theme-secondary">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-bold text-theme-primary mb-4">Why Choose OakStone?</h2>
        <p class="text-lg text-theme-secondary max-w-2xl mx-auto">
          We're committed to making your rental experience as smooth as possible
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="text-center p-6 bg-theme-primary rounded-xl">
          <div class="w-16 h-16 bg-primary-100 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-primary-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-theme-primary mb-2">Quality Properties</h3>
          <p class="text-theme-secondary">
            All our properties are well-maintained and regularly inspected to ensure your comfort.
          </p>
        </div>

        <div class="text-center p-6 bg-theme-primary rounded-xl">
          <div class="w-16 h-16 bg-primary-100 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-primary-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-theme-primary mb-2">Quick Response</h3>
          <p class="text-theme-secondary">
            Our team responds promptly to maintenance requests and inquiries.
          </p>
        </div>

        <div class="text-center p-6 bg-theme-primary rounded-xl">
          <div class="w-16 h-16 bg-primary-100 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-primary-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-theme-primary mb-2">Personal Service</h3>
          <p class="text-theme-secondary">
            We treat every tenant with respect and provide personalized attention to your needs.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-16 gradient-primary text-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl font-bold mb-4">Ready to Find Your New Home?</h2>
      <p class="text-xl text-primary-100 mb-8 max-w-2xl mx-auto">
        Browse our available properties or contact us to learn more about what we have to offer.
      </p>
      <div class="flex flex-col sm:flex-row justify-center gap-4">
        <a
          href="/properties"
          class="inline-flex items-center justify-center px-6 py-3 bg-white text-primary-700 font-semibold rounded-lg hover:bg-primary-50 transition-colors touch-target"
        >
          Browse Properties
        </a>
        <a
          href="/contact"
          class="inline-flex items-center justify-center px-6 py-3 border-2 border-white text-white font-semibold rounded-lg hover:bg-white/10 transition-colors touch-target"
        >
          Get in Touch
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
