### Change 2: Update Dashboard Layout

**File:** `src/pages/Dashboard.tsx`

**Current Implementation:**
```tsx
<Masonry
  breakpointCols={{ default: 3, 1024: 2, 640: 1 }}
  className="masonry-grid"
  columnClassName="masonry-column"
>
  {sortedWidgets.map((widgetId) => {
    const Component = WIDGET_COMPONENTS[widgetId];
    return (
      <div key={widgetId} className="mb-4"> {/* No size class */}
        <Suspense fallback={<WidgetSkeleton />}>
          <Component widgetId={widgetId} />
        </Suspense>
      </div>
    );
  })}
</Masonry>
```

**Proposed Implementation:**
```tsx
const widgetSizes = useWidgetStore((state) => state.widgetSizes);

<Masonry
  breakpointCols={{ default: 3, 1024: 2, 640: 1 }}
  className="masonry-grid"
  columnClassName="masonry-column"
>
  {sortedWidgets.map((widgetId) => {
    const Component = WIDGET_COMPONENTS[widgetId];
    const size = widgetSizes[widgetId] || 1; // Default to 1x
    const sizeClass = size === 3 ? 'col-span-3' : size === 2 ? 'col-span-2' : '';

    return (
      <div key={widgetId} className={`mb-4 ${sizeClass}`}>
        <Suspense fallback={<WidgetSkeleton />}>
          <Component widgetId={widgetId} />
        </Suspense>
      </div>
    );
  })}
</Masonry>
```

**CSS (Add to Dashboard.tsx or global CSS):**
```css
/* Column spanning for masonry layout */
.col-span-2 {
  width: calc(200% + 16px); /* 2 columns + 1 gutter */
}

.col-span-3 {
  width: calc(300% + 32px); /* 3 columns + 2 gutters */
}

/* Responsive: 3x becomes 2x on tablet */
@media (max-width: 1023px) {
  .col-span-3 {
    width: calc(200% + 16px);
  }
}

/* Responsive: All become 1x on mobile */
@media (max-width: 639px) {
  .col-span-2, .col-span-3 {
    width: 100%;
  }
}

/* Smooth transitions */
.masonry-grid > div {
  transition: width 0.3s ease;
}
```

