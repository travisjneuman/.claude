## React Hooks (useLiveQuery)

### Setup

```typescript
// Install: npm install dexie-react-hooks
import { useLiveQuery } from "dexie-react-hooks";
```

### Basic Usage

```typescript
import { useLiveQuery } from "dexie-react-hooks";
import { db } from "./db";

function NotesList() {
  // Automatically re-renders when data changes
  const notes = useLiveQuery(() => db.notes.toArray());

  if (!notes) return <Loading />;

  return (
    <ul>
      {notes.map((note) => (
        <li key={note.id}>{note.title}</li>
      ))}
    </ul>
  );
}
```

### With Dependencies

```typescript
function FolderNotes({ folderId }: { folderId: number }) {
  const notes = useLiveQuery(
    () => db.notes.where("folderId").equals(folderId).toArray(),
    [folderId] // Re-run when folderId changes
  );

  // ...
}
```

### Complex Queries

```typescript
function Dashboard() {
  const stats = useLiveQuery(async () => {
    const [noteCount, taskCount, completedTasks] = await Promise.all([
      db.notes.count(),
      db.tasks.count(),
      db.tasks.where("completed").equals(true).count(),
    ]);

    return { noteCount, taskCount, completedTasks };
  });

  if (!stats) return <Loading />;

  return (
    <div>
      <p>Notes: {stats.noteCount}</p>
      <p>Tasks: {stats.taskCount}</p>
      <p>Completed: {stats.completedTasks}</p>
    </div>
  );
}
```

### With Initial Value

```typescript
function NotesList() {
  const notes = useLiveQuery(
    () => db.notes.orderBy("updatedAt").reverse().toArray(),
    [], // dependencies
    [] // initial value (empty array while loading)
  );

  return (
    <ul>
      {notes.map((note) => (
        <li key={note.id}>{note.title}</li>
      ))}
    </ul>
  );
}
```

