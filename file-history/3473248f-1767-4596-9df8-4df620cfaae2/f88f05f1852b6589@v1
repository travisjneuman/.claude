#!/usr/bin/env python3
"""
Render Handwriting from Notability Files
Extracts curve/stroke data from Session.plist and renders to PNG.
Based on: https://jvns.ca/blog/2018/03/31/reverse-engineering-notability-format/
"""

import os
import zipfile
import plistlib
import struct
import base64
from pathlib import Path
from PIL import Image, ImageDraw
import json

# Configuration
BASE_PATH = Path(r"D:\Proton Drive\My files\Documents\Personal\Notebooks")
OUTPUT_DIR = BASE_PATH / "_converted" / "handwriting_rendered"
LOG_FILE = BASE_PATH / "_scripts" / "output" / "handwriting_render_log.json"

def parse_float_array(data: bytes) -> list:
    """Parse binary data as array of 32-bit floats."""
    num_floats = len(data) // 4
    return list(struct.unpack(f'<{num_floats}f', data[:num_floats * 4]))

def parse_int_array(data: bytes) -> list:
    """Parse binary data as array of 32-bit integers."""
    num_ints = len(data) // 4
    return list(struct.unpack(f'<{num_ints}i', data[:num_ints * 4]))

def parse_color_array(data: bytes) -> list:
    """Parse binary data as array of RGBA colors (4 bytes each)."""
    colors = []
    for i in range(0, len(data), 4):
        if i + 4 <= len(data):
            r, g, b, a = struct.unpack('BBBB', data[i:i+4])
            colors.append((r, g, b, a))
    return colors

def find_curve_data_old_format(plist: dict) -> dict:
    """Extract curve data from older Notability format (direct keys)."""
    result = {}

    for key in ['curvespoints', 'curvesnumpoints', 'curveswidth', 'curvescolors', 'curvesfractionalwidths']:
        if key in plist:
            data = plist[key]
            if isinstance(data, bytes):
                result[key] = data
            elif isinstance(data, str):
                result[key] = base64.b64decode(data)

    return result

def find_curve_data_new_format(plist: dict) -> dict:
    """Extract curve data from newer NSKeyedArchiver/GLKeyedArchiver format."""
    result = {'strokes': []}

    if '$objects' not in plist:
        return result

    objects = plist['$objects']

    # Look for stroke/curve data in objects
    for i, obj in enumerate(objects):
        if isinstance(obj, dict):
            # Look for various stroke-related keys
            for key in obj.keys():
                if 'curve' in key.lower() or 'stroke' in key.lower() or 'point' in key.lower():
                    print(f"  Found key: {key}")

            # Check for NS.bytes which often contains curve data
            if 'NS.bytes' in obj:
                data = obj['NS.bytes']
                if len(data) > 100:  # Significant data
                    result['raw_bytes'].append({
                        'index': i,
                        'size': len(data),
                        'data': data
                    })

    return result

def extract_handwriting_data(note_path: Path) -> dict:
    """Extract handwriting/curve data from a .note file."""
    result = {
        'success': False,
        'format': None,
        'curves': None,
        'canvas_size': (1118, 1484),  # Default Notability canvas
    }

    try:
        with zipfile.ZipFile(note_path, 'r') as z:
            # Find Session.plist
            session_path = None
            for name in z.namelist():
                if 'Session.plist' in name:
                    session_path = name
                    break

            if not session_path:
                result['error'] = 'No Session.plist found'
                return result

            data = z.read(session_path)
            plist = plistlib.loads(data)

            # Check format
            if '$archiver' in plist:
                result['format'] = plist['$archiver']
                curves = find_curve_data_new_format(plist)
            else:
                result['format'] = 'legacy'
                curves = find_curve_data_old_format(plist)

            result['curves'] = curves
            result['success'] = bool(curves)

    except Exception as e:
        result['error'] = str(e)

    return result

def render_strokes(curves: dict, canvas_size: tuple = (1118, 1484)) -> Image.Image:
    """Render strokes to an image."""
    # Create white canvas
    img = Image.new('RGB', canvas_size, (255, 255, 255))
    draw = ImageDraw.Draw(img)

    if 'curvespoints' not in curves:
        return img

    # Parse data
    points = parse_float_array(curves['curvespoints'])

    if 'curvesnumpoints' in curves:
        num_points = parse_int_array(curves['curvesnumpoints'])
    else:
        # Assume single stroke
        num_points = [len(points) // 2]

    if 'curvescolors' in curves:
        colors = parse_color_array(curves['curvescolors'])
    else:
        colors = [(0, 0, 0, 255)] * len(num_points)  # Default black

    if 'curveswidth' in curves:
        widths = parse_float_array(curves['curveswidth'])
    else:
        widths = [2.0] * len(num_points)  # Default width

    # Draw strokes
    point_idx = 0
    for stroke_idx, num_pts in enumerate(num_points):
        if stroke_idx >= len(colors):
            color = (0, 0, 0, 255)
        else:
            color = colors[stroke_idx]

        if stroke_idx >= len(widths):
            width = 2
        else:
            width = max(1, int(widths[stroke_idx]))

        # Get points for this stroke
        stroke_points = []
        for _ in range(num_pts):
            if point_idx * 2 + 1 < len(points):
                x = points[point_idx * 2]
                y = points[point_idx * 2 + 1]
                stroke_points.append((x, y))
            point_idx += 1

        # Draw the stroke
        if len(stroke_points) >= 2:
            # Convert color from RGBA to RGB for PIL
            rgb = (color[0], color[1], color[2])
            draw.line(stroke_points, fill=rgb, width=width)

    return img

def process_note_file(note_path: Path, output_dir: Path) -> dict:
    """Process a single .note file and render handwriting."""
    result = {
        'source': str(note_path),
        'success': False,
    }

    data = extract_handwriting_data(note_path)

    if not data['success']:
        result['error'] = data.get('error', 'No curve data found')
        result['format'] = data.get('format')
        return result

    if data['curves'] and ('curvespoints' in data['curves'] or data['curves'].get('strokes')):
        try:
            img = render_strokes(data['curves'], data['canvas_size'])

            # Save output
            safe_name = note_path.stem.replace('/', '_').replace('\\', '_')
            output_path = output_dir / f"{safe_name}.png"

            counter = 1
            while output_path.exists():
                output_path = output_dir / f"{safe_name}_{counter}.png"
                counter += 1

            img.save(output_path)

            result['success'] = True
            result['output'] = str(output_path)
            result['format'] = data['format']
        except Exception as e:
            result['error'] = str(e)
    else:
        result['error'] = 'No renderable curve data'
        result['format'] = data.get('format')

    return result

def find_note_files() -> list:
    """Find all .note files."""
    files = []
    for root, dirs, filenames in os.walk(BASE_PATH):
        if '_converted' in root or '_scripts' in root or '_organized' in root:
            continue
        for f in filenames:
            if f.endswith('.note'):
                files.append(Path(root) / f)
    return files

def main():
    print("=" * 60)
    print("Render Handwriting from Notability Files")
    print("=" * 60)

    OUTPUT_DIR.mkdir(parents=True, exist_ok=True)

    # Test with a few files first
    files = find_note_files()[:10]
    print(f"\nTesting with {len(files)} files...")

    log = {
        'tested': [],
        'rendered': 0,
        'failed': 0,
        'formats_found': {},
    }

    for note_path in files:
        print(f"\nProcessing: {note_path.name}")
        result = process_note_file(note_path, OUTPUT_DIR)
        log['tested'].append(result)

        if result['success']:
            log['rendered'] += 1
            print(f"  SUCCESS: {result.get('output')}")
        else:
            log['failed'] += 1
            print(f"  FAILED: {result.get('error')}")

        fmt = result.get('format', 'unknown')
        log['formats_found'][fmt] = log['formats_found'].get(fmt, 0) + 1

    # Save log
    with open(LOG_FILE, 'w', encoding='utf-8') as f:
        json.dump(log, f, indent=2, default=str)

    print("\n" + "=" * 60)
    print("TEST RESULTS")
    print("=" * 60)
    print(f"Files tested: {len(files)}")
    print(f"Successfully rendered: {log['rendered']}")
    print(f"Failed: {log['failed']}")
    print(f"Formats found: {log['formats_found']}")
    print("=" * 60)

if __name__ == '__main__':
    main()
