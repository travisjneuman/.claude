## Phase 2: Error Boundary Layer (Resilience)

### 2.1 Create Store Error Boundary

**File:** `src/components/StoreErrorBoundary.tsx`

**Purpose:** Catch store-related render errors, show recovery UI instead of blank screen.

```typescript
interface StoreErrorBoundaryProps {
  storeName: string;
  children: React.ReactNode;
  fallback?: React.ReactNode;
}

export class StoreErrorBoundary extends React.Component<
  StoreErrorBoundaryProps,
  { hasError: boolean; error: Error | null }
> {
  state = { hasError: false, error: null };

  static getDerivedStateFromError(error: Error) {
    return { hasError: true, error };
  }

  componentDidCatch(error: Error, info: ErrorInfo) {
    logger.error(`Store error in ${this.props.storeName}`, { error, info });

    // Optionally report to error service
    errorService.report(error, {
      context: 'store-error-boundary',
      store: this.props.storeName,
    });
  }

  handleReset = async () => {
    // Option 1: Clear this store's data
    // Option 2: Reload from last backup
    // Option 3: Full app reset

    this.setState({ hasError: false, error: null });
  };

  render() {
    if (this.state.hasError) {
      return this.props.fallback || (
        <ErrorRecoveryUI
          storeName={this.props.storeName}
          error={this.state.error}
          onReset={this.handleReset}
        />
      );
    }
    return this.props.children;
  }
}
```

