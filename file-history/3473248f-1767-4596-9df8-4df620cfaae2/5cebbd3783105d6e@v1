#!/usr/bin/env python3
"""
Extract High-Resolution Thumbnails from Notability Files
Extracts thumb6x.png (highest resolution) from all .note files.
These thumbnails show the full note content including native handwriting.
"""

import os
import zipfile
from pathlib import Path
from datetime import datetime
import json

# Configuration
BASE_PATH = Path(r"D:\Proton Drive\My files\Documents\Personal\Notebooks")
OUTPUT_DIR = BASE_PATH / "_converted" / "thumbnails_hires"
LOG_FILE = BASE_PATH / "_scripts" / "output" / "thumbnail_extraction_log.json"

def sanitize_filename(name: str) -> str:
    """Sanitize filename for filesystem."""
    import re
    invalid_chars = '<>:"/\\|?*'
    for char in invalid_chars:
        name = name.replace(char, '_')
    name = re.sub(r'[_\s]+', ' ', name).strip()
    if len(name) > 200:
        name = name[:200]
    return name

def extract_best_thumbnail(note_path: Path, output_dir: Path) -> dict:
    """Extract the highest resolution thumbnail from a .note file."""
    result = {
        'source': str(note_path),
        'success': False,
        'thumbnail_size': None,
        'output': None,
    }

    # Priority order - highest resolution first
    thumb_priority = ['thumb6x.png', 'thumb3x.png', 'thumb2x.png', 'thumb.png', 'thumbnail2x', 'thumbnail']

    try:
        with zipfile.ZipFile(note_path, 'r') as z:
            namelist = z.namelist()

            # Find best available thumbnail
            best_thumb = None
            for thumb_name in thumb_priority:
                for name in namelist:
                    if name.endswith(thumb_name):
                        best_thumb = name
                        break
                if best_thumb:
                    break

            if best_thumb:
                # Extract thumbnail
                data = z.read(best_thumb)

                # Determine output filename
                safe_name = sanitize_filename(note_path.stem)

                # Determine extension
                if best_thumb.endswith('.png'):
                    ext = '.png'
                else:
                    # Check if it's actually a PNG by magic bytes
                    if data[:8] == b'\x89PNG\r\n\x1a\n':
                        ext = '.png'
                    else:
                        ext = '.jpg'

                output_path = output_dir / f"{safe_name}{ext}"

                # Handle duplicates
                counter = 1
                while output_path.exists():
                    output_path = output_dir / f"{safe_name}_{counter}{ext}"
                    counter += 1

                # Write thumbnail
                with open(output_path, 'wb') as f:
                    f.write(data)

                result['success'] = True
                result['thumbnail_size'] = len(data)
                result['output'] = str(output_path)
                result['thumb_type'] = best_thumb.split('/')[-1]
            else:
                result['error'] = 'No thumbnail found'

    except Exception as e:
        result['error'] = str(e)

    return result

def find_note_files() -> list:
    """Find all .note files."""
    files = []
    for root, dirs, filenames in os.walk(BASE_PATH):
        # Skip output directories
        if '_converted' in root or '_scripts' in root or '_organized' in root:
            continue
        for f in filenames:
            if f.endswith('.note'):
                files.append(Path(root) / f)
    return files

def main():
    print("=" * 60)
    print("Extract High-Resolution Thumbnails")
    print("=" * 60)

    # Create output directory
    OUTPUT_DIR.mkdir(parents=True, exist_ok=True)

    # Find all .note files
    files = find_note_files()
    print(f"\nFound {len(files)} .note files")

    if not files:
        print("No .note files to process!")
        return

    # Process each file
    log = {
        'processed': [],
        'errors': [],
        'stats': {
            'total': len(files),
            'success': 0,
            'failed': 0,
            'thumb6x': 0,
            'thumb3x': 0,
            'thumb2x': 0,
            'other': 0,
        }
    }

    for i, note_path in enumerate(files):
        print(f"\r  Processing {i+1}/{len(files)}: {note_path.name[:40]}...", end='', flush=True)

        result = extract_best_thumbnail(note_path, OUTPUT_DIR)

        if result['success']:
            log['stats']['success'] += 1
            thumb_type = result.get('thumb_type', '')
            if 'thumb6x' in thumb_type:
                log['stats']['thumb6x'] += 1
            elif 'thumb3x' in thumb_type:
                log['stats']['thumb3x'] += 1
            elif 'thumb2x' in thumb_type:
                log['stats']['thumb2x'] += 1
            else:
                log['stats']['other'] += 1
            log['processed'].append(result)
        else:
            log['stats']['failed'] += 1
            log['errors'].append(result)

    # Write log
    print(f"\n\nWriting log to: {LOG_FILE}")
    with open(LOG_FILE, 'w', encoding='utf-8') as f:
        json.dump(log, f, indent=2)

    # Print summary
    print("\n" + "=" * 60)
    print("THUMBNAIL EXTRACTION SUMMARY")
    print("=" * 60)
    print(f"Total .note files: {log['stats']['total']}")
    print(f"Successfully extracted: {log['stats']['success']}")
    print(f"  - thumb6x (highest): {log['stats']['thumb6x']}")
    print(f"  - thumb3x: {log['stats']['thumb3x']}")
    print(f"  - thumb2x: {log['stats']['thumb2x']}")
    print(f"  - other: {log['stats']['other']}")
    print(f"Failed: {log['stats']['failed']}")
    print(f"\nThumbnails saved to: {OUTPUT_DIR}")
    print("=" * 60)

if __name__ == '__main__':
    main()
