// Bulk status change
bulkUpdateStatus: (taskIds: string[], newStatus: TaskStatus) => {
  set(state => ({
    tasks: state.tasks.map(task =>
      taskIds.includes(task.id) ? { ...task, status: newStatus } : task
    ),
  }));
  // Log activity for each task
};

// Bulk priority change
bulkUpdatePriority: (taskIds: string[], newPriority: TaskPriority) => {
  set(state => ({
    tasks: state.tasks.map(task =>
      taskIds.includes(task.id) ? { ...task, priority: newPriority } : task
    ),
  }));
};

// Bulk delete
bulkDeleteTasks: (taskIds: string[]) => {
  // Save undo state before deleting
  get().addToUndoHistory({
    action: 'bulkDelete',
    description: `Deleted ${taskIds.length} tasks`,
    previousState: {
      columns: get().columns,
      tasks: get().tasks,
    },
  });

  set(state => ({
    tasks: state.tasks.filter(task => !taskIds.includes(task.id)),
  }));
};
```

### Part 5: Export to CSV (1-2 hours)

**File:** `src/lib/exportCSV.ts` (new utility)

**Implementation:**
```typescript
export function exportTasksToCSV(tasks: Task[], columns: KanbanColumn[]): void {
  const headers = ['Title', 'Status', 'Priority', 'Due Date', 'Tags', 'Checklist Progress'];
  const rows = tasks.map(task => {
    const status = columns.find(col => col.id === task.status)?.title || task.status;
    const completedItems = task.checklist?.filter(item => item.completed).length || 0;
    const totalItems = task.checklist?.length || 0;
    const progress = totalItems > 0 ? `${completedItems}/${totalItems}` : 'N/A';

    return [
      task.title,
      status,
      task.priority,
      task.dueDate || 'N/A',
      task.tags.join(', '),
      progress,
    ];
  });

  const csv = [headers, ...rows].map(row => row.join(',')).join('\n');
  const blob = new Blob([csv], { type: 'text/csv' });
  const url = URL.createObjectURL(blob);
  const a = document.createElement('a');
  a.href = url;
  a.download = `kanban-tasks-${new Date().toISOString().split('T')[0]}.csv`;
  a.click();
  URL.revokeObjectURL(url);
}
```

