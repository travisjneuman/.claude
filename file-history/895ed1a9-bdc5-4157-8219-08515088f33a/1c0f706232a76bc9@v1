### Template 3: Action Card Widget

Use for: Quick actions, shortcuts

```tsx
import React from 'react';

interface ActionCardWidgetProps {
  title: string;
  description: string;
  actions: Array<{ id: string; label: string; onClick: () => void; icon?: React.ReactNode }>;
}

export const ActionCardWidget: React.FC<ActionCardWidgetProps> = ({
  title,
  description,
  actions,
}) => {
  return (
    <div className="p-4 bg-surface-light dark:bg-surface-dark rounded-card shadow-card">
      <div className="space-y-4">
        {/* Header */}
        <section>
          <h3 className="text-sm font-semibold text-text-light-primary dark:text-text-dark-primary mb-2">
            {title}
          </h3>
          <p className="text-xs text-text-light-secondary dark:text-text-dark-secondary">
            {description}
          </p>
        </section>

        {/* Actions */}
        <div className="grid grid-cols-2 gap-2">
          {actions.map((action) => (
            <button
              key={action.id}
              onClick={action.onClick}
              className="px-4 py-2 rounded-lg bg-surface-light-elevated dark:bg-surface-dark-elevated hover:bg-surface-light dark:hover:bg-surface-dark text-text-light-primary dark:text-text-dark-primary font-medium transition-colors border border-border-light dark:border-border-dark flex items-center justify-center gap-2"
            >
              {action.icon}
              <span className="text-sm">{action.label}</span>
            </button>
          ))}
        </div>
      </div>
    </div>
  );
};
```

**Usage:**
```tsx
<ActionCardWidget
  title="Quick Actions"
  description="Common tasks at your fingertips"
  actions={[
    { id: '1', label: 'New Task', onClick: () => {}, icon: <PlusIcon /> },
    { id: '2', label: 'New Note', onClick: () => {}, icon: <DocumentIcon /> },
    { id: '3', label: 'New Event', onClick: () => {}, icon: <CalendarIcon /> },
    { id: '4', label: 'Settings', onClick: () => {}, icon: <CogIcon /> },
  ]}
/>
```

