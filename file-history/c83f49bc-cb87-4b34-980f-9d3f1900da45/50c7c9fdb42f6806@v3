### 2. Store Architecture
**File:** `src/stores/useTimeTrackingStore.ts` (new)

```typescript
interface TimeTrackingStore {
  // Active timer state
  activeTimer: {
    id?: string;
    startTime?: string;
    description?: string;
    projectId?: string;
    taskId?: string;
  } | null;

  // Actions
  startTimer: (description: string, projectId?: string, taskId?: string) => void;
  stopTimer: () => Promise<void>;
  pauseTimer: () => void;
  resumeTimer: () => void;

  // Manual entry
  addTimeEntry: (entry: Omit<TimeEntry, 'id'>) => Promise<void>;
  updateTimeEntry: (id: string, updates: Partial<TimeEntry>) => Promise<void>;
  deleteTimeEntry: (id: string) => Promise<void>;

  // Queries (cached)
  getTodayEntries: () => Promise<TimeEntry[]>;
  getWeekEntries: () => Promise<TimeEntry[]>;
  getEntriesByDateRange: (start: Date, end: Date) => Promise<TimeEntry[]>;

  // Analytics
  getTodayTotal: () => number;
  getWeekTotal: () => number;
  getProjectBreakdown: (start: Date, end: Date) => Record<string, number>;

  // Goals
  weeklyGoal?: number; // hours
  setWeeklyGoal: (hours: number) => void;
}
```

