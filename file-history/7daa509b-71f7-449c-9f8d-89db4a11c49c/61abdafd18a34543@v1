def get_db():
    db = SessionLocal()
    try:
        yield db
    finally:
        db.close()

def get_current_user(db: Session = Depends(get_db)):
    # Get user from auth token
    return user

@app.get("/users/me")
def read_current_user(user: User = Depends(get_current_user)):
