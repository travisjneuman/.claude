**Implementation:**
```typescript
// src/types/index.ts
export interface TaskDependency {
  id: string;
  sourceTaskId: string; // Task that blocks
  targetTaskId: string; // Task that is blocked
  type: 'blocks' | 'blocked-by'; // Redundant but clearer
  createdAt: Date;
}

export interface KanbanState {
  // ... existing fields
  dependencies: TaskDependency[]; // NEW
}

// src/stores/useKanbanStore.ts
addDependency: (sourceTaskId: string, targetTaskId: string) => {
  const dependency: TaskDependency = {
    id: uuidv4(),
    sourceTaskId,
    targetTaskId,
    type: 'blocks',
    createdAt: new Date(),
  };

  set((state) => ({
    dependencies: [...state.dependencies, dependency]
  }));

  // Log activity
  get().logActivity(sourceTaskId, {
    action: 'created',
    field: 'dependency',
    newValue: `Blocks task ${targetTaskId}`,
  });

  get().logActivity(targetTaskId, {
    action: 'created',
    field: 'dependency',
    newValue: `Blocked by task ${sourceTaskId}`,
  });
},
```

