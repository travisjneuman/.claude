### Template 2: Grid Widget

Use for: Stats, Metrics, Quick Actions

```tsx
import React from 'react';

interface GridWidgetProps {
  title: string;
  items: Array<{ id: string; label: string; value: string | number; icon?: React.ReactNode }>;
  columns?: 2 | 3;
}

export const GridWidget: React.FC<GridWidgetProps> = ({
  title,
  items,
  columns = 2,
}) => {
  return (
    <div className="p-4 bg-surface-light dark:bg-surface-dark rounded-card shadow-card">
      <div className="space-y-4">
        {/* Header */}
        <h3 className="text-sm font-semibold text-text-light-primary dark:text-text-dark-primary">
          {title}
        </h3>

        {/* Grid */}
        <div className={`grid grid-cols-${columns} gap-3`}>
          {items.map((item) => (
            <div
              key={item.id}
              className="p-3 bg-surface-light-elevated dark:bg-surface-dark-elevated rounded-lg"
            >
              {item.icon && <div className="mb-2">{item.icon}</div>}
              <p className="text-xs text-text-light-secondary dark:text-text-dark-secondary mb-1">
                {item.label}
              </p>
              <p className="text-lg font-semibold text-text-light-primary dark:text-text-dark-primary">
                {item.value}
              </p>
            </div>
          ))}
        </div>
      </div>
    </div>
  );
};
```

**Usage:**
```tsx
<GridWidget
  title="Today's Stats"
  columns={3}
  items={[
    { id: '1', label: 'Tasks Done', value: 12 },
    { id: '2', label: 'Events', value: 3 },
    { id: '3', label: 'Notes', value: 8 },
  ]}
/>
```

