import React from 'react';
import { useSortable } from '@dnd-kit/sortable';
import { CSS } from '@dnd-kit/utilities';

interface SortableWidgetProps {
  id: string;
  children: React.ReactNode;
  className?: string;
}

/**
 * Wrapper component to make dashboard widgets sortable via drag-drop
 * Uses @dnd-kit for drag-drop functionality
 *
 * NOTE: Drag listeners are passed to children (Widget component) to apply to header only.
 * This prevents drag conflicts with interactive content like maps.
 */
export const SortableWidget: React.FC<SortableWidgetProps> = ({ id, children, className = '' }) => {
  const {
    attributes,
    listeners,
    setNodeRef,
    transform,
    transition,
    isDragging,
  } = useSortable({ id });

  const style = {
    transform: CSS.Transform.toString(transform),
    transition,
    opacity: isDragging ? 0.5 : 1,
  };

  return (
    <div
      ref={setNodeRef}
      style={style}
      className={`sortable-widget ${className}`}
      {...attributes}
    >
      {React.isValidElement(children)
        ? React.cloneElement(children, { dragListeners: listeners } as any)
        : children}
    </div>
  );
};
