#!/usr/bin/env python3
"""
High-Resolution PDF Renderer
Renders embedded PDFs at 300 DPI for clear, readable handwriting.
"""

import os
import zipfile
import json
import fitz  # PyMuPDF
from pathlib import Path

# Configuration
BASE_PATH = Path(r"D:\Proton Drive\My files\Documents\Personal\Notebooks")
OUTPUT_DIR = BASE_PATH / "_converted" / "pdf_hires"
LOG_FILE = BASE_PATH / "_scripts" / "output" / "pdf_hires_log.json"

# HIGH QUALITY SETTINGS
DPI = 300  # 300 DPI for clear text/handwriting
MAX_PAGES = 100  # Allow more pages


def sanitize_filename(name: str) -> str:
    import re
    invalid_chars = '<>:"/\\|?*'
    for char in invalid_chars:
        name = name.replace(char, '_')
    name = re.sub(r'[_\s]+', ' ', name).strip()
    if len(name) > 150:
        name = name[:150]
    return name


def render_pdf_hires(note_path: Path, output_dir: Path) -> dict:
    result = {
        'source': str(note_path),
        'success': False,
        'pages': 0,
        'outputs': [],
    }

    try:
        with zipfile.ZipFile(note_path, 'r') as z:
            pdf_files = [n for n in z.namelist() if n.endswith('.pdf')]

            if not pdf_files:
                result['error'] = 'No PDFs'
                return result

            safe_name = sanitize_filename(note_path.stem)
            note_output_dir = output_dir / safe_name
            note_output_dir.mkdir(parents=True, exist_ok=True)

            for pdf_name in pdf_files:
                pdf_data = z.read(pdf_name)

                try:
                    doc = fitz.open(stream=pdf_data, filetype='pdf')
                    page_count = min(doc.page_count, MAX_PAGES)

                    for page_num in range(page_count):
                        page = doc[page_num]

                        # High quality render at 300 DPI
                        zoom = DPI / 72
                        matrix = fitz.Matrix(zoom, zoom)
                        pix = page.get_pixmap(matrix=matrix)

                        if page_count == 1:
                            output_name = f"{safe_name}.png"
                        else:
                            output_name = f"{safe_name}_p{page_num + 1:03d}.png"

                        output_path = note_output_dir / output_name
                        pix.save(str(output_path))

                        result['outputs'].append(str(output_path))
                        result['pages'] += 1

                    doc.close()

                except Exception as e:
                    result['pdf_error'] = str(e)

            result['success'] = result['pages'] > 0

    except Exception as e:
        result['error'] = str(e)

    return result


def find_note_files_with_pdfs() -> list:
    files = []
    for root, dirs, filenames in os.walk(BASE_PATH):
        if '_converted' in root or '_scripts' in root or '_organized' in root:
            continue
        for f in filenames:
            if f.endswith('.note'):
                note_path = Path(root) / f
                try:
                    with zipfile.ZipFile(note_path, 'r') as z:
                        if any(n.endswith('.pdf') for n in z.namelist()):
                            files.append(note_path)
                except:
                    pass
    return files


def main():
    print("=" * 60)
    print("High-Resolution PDF Renderer (300 DPI)")
    print("=" * 60)

    OUTPUT_DIR.mkdir(parents=True, exist_ok=True)

    files = find_note_files_with_pdfs()
    print(f"\nFound {len(files)} notes with PDFs")

    log = {
        'stats': {'total': len(files), 'success': 0, 'pages': 0, 'errors': 0},
        'processed': [],
        'errors': [],
    }

    for i, note_path in enumerate(files):
        if i % 25 == 0:
            print(f"\r  Processing {i+1}/{len(files)}...", end='', flush=True)

        result = render_pdf_hires(note_path, OUTPUT_DIR)

        if result['success']:
            log['stats']['success'] += 1
            log['stats']['pages'] += result['pages']
            log['processed'].append({
                'source': str(note_path),
                'pages': result['pages'],
            })
        else:
            log['stats']['errors'] += 1
            log['errors'].append({
                'source': str(note_path),
                'error': result.get('error', result.get('pdf_error')),
            })

    print(f"\n\nWriting log...")
    with open(LOG_FILE, 'w', encoding='utf-8') as f:
        json.dump(log, f, indent=2)

    print("\n" + "=" * 60)
    print("HIGH-RES RENDER COMPLETE")
    print("=" * 60)
    print(f"Notes: {log['stats']['success']}/{log['stats']['total']}")
    print(f"Pages: {log['stats']['pages']}")
    print(f"Errors: {log['stats']['errors']}")
    print(f"\nOutput: {OUTPUT_DIR}")
    print("=" * 60)


if __name__ == '__main__':
    main()
