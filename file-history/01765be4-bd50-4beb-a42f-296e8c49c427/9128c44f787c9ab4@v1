import { useEffect, useState } from 'react';
import { getDirectoryHandle, autoSaveWithRotation } from '../services/brainBackup';

export function useAutoSave(intervalMs = 5000) {
  const [lastSaveTime, setLastSaveTime] = useState<Date | null>(null);
  const [autoSaveEnabled, setAutoSaveEnabled] = useState(false);

  useEffect(() => {
    // Check if auto-save directory is set
    getDirectoryHandle().then((handle) => {
      setAutoSaveEnabled(!!handle);
    });
  }, []);

  useEffect(() => {
    if (!autoSaveEnabled) return;

    const interval = setInterval(async () => {
      try {
        await autoSaveWithRotation();
        setLastSaveTime(new Date());
        console.log('✅ Auto-saved');
      } catch (error) {
        console.error('Auto-save failed:', error);
      }
    }, intervalMs);

    return () => clearInterval(interval);
  }, [autoSaveEnabled, intervalMs]);

  return {
    autoSaveEnabled,
    lastSaveTime,
  };
}
```

