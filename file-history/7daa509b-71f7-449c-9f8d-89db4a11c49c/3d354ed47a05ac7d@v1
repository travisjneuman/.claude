## CRUD Operations

### Create

```typescript
// Add single item
const id = await db.notes.add({
  title: "New Note",
  content: "Content here",
  createdAt: new Date(),
  updatedAt: new Date(),
  tags: ["work", "important"],
});

// Add multiple items
const ids = await db.notes.bulkAdd([
  { title: "Note 1", content: "...", createdAt: new Date(), updatedAt: new Date(), tags: [] },
  { title: "Note 2", content: "...", createdAt: new Date(), updatedAt: new Date(), tags: [] },
]);

// Put (insert or update)
await db.notes.put({
  id: 1,
  title: "Updated Title",
  content: "...",
  createdAt: new Date(),
  updatedAt: new Date(),
  tags: [],
});
```

### Read

```typescript
// Get by primary key
const note = await db.notes.get(1);

// Get all
const allNotes = await db.notes.toArray();

// Get with filter
const recentNotes = await db.notes
  .where("createdAt")
  .above(new Date("2024-01-01"))
  .toArray();

// First match
const firstNote = await db.notes
  .where("title")
  .equals("My Note")
  .first();

// Count
const count = await db.notes.count();
const filteredCount = await db.notes
  .where("completed")
  .equals(true)
  .count();
```

### Update

```typescript
// Update by primary key
await db.notes.update(1, {
  title: "Updated Title",
  updatedAt: new Date(),
});

// Modify with function
await db.notes.where("id").equals(1).modify((note) => {
  note.title = "Modified Title";
  note.updatedAt = new Date();
});

// Bulk update
await db.notes
  .where("folderId")
  .equals(oldFolderId)
  .modify({ folderId: newFolderId });
```

### Delete

```typescript
// Delete by primary key
await db.notes.delete(1);

// Delete multiple
await db.notes.bulkDelete([1, 2, 3]);

// Delete with filter
await db.notes.where("folderId").equals(deletedFolderId).delete();

// Clear all
await db.notes.clear();
```

