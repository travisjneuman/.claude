## Best Practices

### Do

```typescript
// Prefer interfaces for objects
interface User {
  id: string;
  name: string;
}

// Use explicit return types for public APIs
function getUser(id: string): User | null {
  // ...
}

// Use `unknown` instead of `any`
function parseJSON(json: string): unknown {
  return JSON.parse(json);
}

// Use const assertions for literals
const COLORS = ["red", "green", "blue"] as const;
type Color = typeof COLORS[number]; // "red" | "green" | "blue"

// Use discriminated unions for variants
type Result<T> =
  | { success: true; data: T }
  | { success: false; error: Error };
```

### Don't

```typescript
// Don't use `any` (use `unknown`)
function bad(data: any) {} // Bad
function good(data: unknown) {} // Good

// Don't use non-null assertion unless necessary
const element = document.getElementById("app")!; // Risky
const element = document.getElementById("app"); // Better
if (element) { /* use element */ }

// Don't use `Function` type
type BadCallback = Function; // Bad
type GoodCallback = () => void; // Good

// Don't use `Object` or `{}`
type BadObject = Object; // Bad
type GoodObject = Record<string, unknown>; // Good
```

