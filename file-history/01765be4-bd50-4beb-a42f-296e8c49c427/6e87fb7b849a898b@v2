@tailwind base;
@tailwind components;
@tailwind utilities;

@layer base {
  body {
    margin: 0;
    min-height: 100vh;
    font-family: 'Inter', system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
    font-size: 14px;
    @apply bg-surface-light dark:bg-surface-dark;
    @apply text-text-light-primary dark:text-text-dark-primary;
  }

  /* Focus styles for accessibility (WCAG 2.2 compliant) */
  *:focus-visible {
    @apply outline-2 outline-accent-blue-hover;
    outline-offset: 2px;
    border-radius: 4px;
  }
}

/* Scrollbar styling for sidebar */
@layer utilities {
  .scrollbar-thin::-webkit-scrollbar {
    width: 6px;
  }

  .scrollbar-thin::-webkit-scrollbar-track {
    background: transparent;
  }

  .scrollbar-thin::-webkit-scrollbar-thumb {
    @apply bg-border-light;
    border-radius: 3px;
  }

  .dark .scrollbar-thin::-webkit-scrollbar-thumb {
    @apply bg-border-dark;
  }

  /* Dashboard widget sizing (masonry column spanning) */
  .col-span-2 {
    width: calc(200% + 24px); /* 2 columns + 1 gutter (24px) */
  }

  .col-span-3 {
    width: calc(300% + 48px); /* 3 columns + 2 gutters (48px) */
  }

  /* Responsive: 3x becomes 2x on tablet (2 columns) */
  @media (max-width: 1023px) {
    .col-span-3 {
      width: calc(200% + 24px);
    }
  }

  /* Responsive: All become 1x on mobile (1 column) */
  @media (max-width: 639px) {
    .col-span-2,
    .col-span-3 {
      width: 100%;
    }
  }

  /* Smooth transitions for size changes */
  .masonry-grid > div {
    transition: width 0.3s ease;
  }
}
